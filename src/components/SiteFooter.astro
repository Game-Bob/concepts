---
import Footer from "@jjlmoya/identity/footer";
import packageJson from "../../package.json";
import { getBrand } from "../identity/brands";
import type { Language } from "../i18n/languages";

interface Props {
    language: Language;
}

const { language } = Astro.props;
const version = (import.meta.env.PUBLIC_APP_VERSION || packageJson.version).replace(/^v/, "");
---

<Footer class="concepts-site-footer" identity={getBrand(language)} {language} {version} />
