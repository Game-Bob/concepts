---
import ShareableQuote from "./WheatShareableQuote.astro";

import type { WheatTexts } from "../../concepts/wheat/types";

interface Props {
    texts: WheatTexts["surplus"];
    common: WheatTexts["common"];
}

const { texts, common } = Astro.props;
---

<section
    id="excedente"
    class="wheat-relative wheat-font-serif wheat-min-h-screen wheat-flex wheat-items-center wheat-justify-center wheat-py-12 wheat-py-24@md wheat-surplus"
>
    <div class="wheat-container wheat-container--wide">
        <div class="wheat-surplus-grid wheat-items-center">
            <div
                class="wheat-surplus-col-left wheat-flex wheat-flex-col wheat-items-center wheat-justify-center"
            >
                <div
                    class="wheat-relative wheat-w-full wheat-surplus-visual wheat-p-4 wheat-p-8@md wheat-flex wheat-flex-col-reverse wheat-items-center wheat-gap-1 wheat-overflow-hidden"
                >
                    <div class="wheat-surplus-grain wheat-surplus-grain--9"></div>
                    <div class="wheat-surplus-grain wheat-surplus-grain--8"></div>
                    <div class="wheat-surplus-grain wheat-surplus-grain--7"></div>
                    <div class="wheat-surplus-grain wheat-surplus-grain--6"></div>
                    <div class="wheat-surplus-grain wheat-surplus-grain--5"></div>
                    <div class="wheat-surplus-grain wheat-surplus-grain--4"></div>
                    <div class="wheat-surplus-grain wheat-surplus-grain--3"></div>
                    <div class="wheat-surplus-grain wheat-surplus-grain--2"></div>
                    <div class="wheat-surplus-grain wheat-surplus-grain--1"></div>

                    <div class="wheat-absolute wheat-surplus-caption wheat-font-mono">
                        {texts.figureLabel}
                    </div>
                </div>
            </div>

            <div class="wheat-surplus-col-right wheat-space-y-8">
                <div>
                    <span
                        class="trigo-chapter wheat-surplus-chapter wheat-text-xs wheat-text-sm@md wheat-tracking-widest wheat-uppercase"
                    >
                        {texts.chapter}
                    </span>
                    <h2
                        class="wheat-text-3xl wheat-text-4xl@md wheat-font-bold wheat-surplus-title wheat-mt-4"
                    >
                        {texts.title}
                    </h2>
                </div>

                <p
                    class="wheat-text-base wheat-text-lg@md wheat-leading-relaxed wheat-surplus-desc"
                >
                    {texts.storageLead}
                    <strong class="wheat-font-bold wheat-surplus-strong"
                        >{texts.storageEmphasis}</strong
                    >{texts.storageConclusion}
                </p>

                <p
                    class="wheat-text-base wheat-text-lg@md wheat-leading-relaxed wheat-surplus-desc"
                >
                    <ShareableQuote quote={texts.povertyQuote} shareLabel={common.shareIdea} />
                    {texts.inequality}
                </p>

                <p
                    class="wheat-text-base wheat-text-lg@md wheat-leading-relaxed wheat-surplus-desc"
                >
                    {texts.power}
                </p>

                <div class="wheat-surplus-card wheat-p-4 wheat-p-6@md wheat-rounded wheat-border">
                    <h3
                        class="wheat-text-base wheat-text-lg@md wheat-font-bold wheat-surplus-card-title wheat-mb-2"
                    >
                        {texts.doubtTitle}
                    </h3>
                    <p class="wheat-text-sm wheat-text-base@md wheat-surplus-card-desc">
                        {texts.doubtText}
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .wheat-surplus {
        color: var(--wheat-stone-200);
        border-top: 1px solid rgb(120 53 4 / 0.1);
    }

    .wheat-surplus-grid {
        display: grid;
        grid-template-columns: repeat(1, 1fr);
        gap: 2rem;
        width: 100%;
    }

    @media (width >= 768px) {
        .wheat-surplus-grid {
            grid-template-columns: repeat(12, 1fr);
            gap: 3rem;
        }

        .wheat-surplus-col-left {
            grid-column: span 5;
        }

        .wheat-surplus-col-right {
            grid-column: span 7;
        }

        .wheat-p-8\@md {
            padding: 2rem;
        }

        .wheat-p-6\@md {
            padding: 1.5rem;
        }
    }

    .wheat-surplus-visual {
        max-width: 20rem;
        aspect-ratio: 1/1;
        background-color: var(--wheat-stone-950);
        border: 1px solid rgb(146 64 14 / 0.2);
        box-sizing: border-box;
    }

    @media (width >= 768px) {
        .wheat-surplus-visual {
            max-width: 100%;
        }
    }

    .wheat-surplus-grain {
        width: 100%;
        height: 0.75rem;
        background-color: rgb(146 64 14 / 0.2);
        border: 1px solid rgb(146 64 14 / 0.4);
        box-sizing: border-box;
    }

    @media (width >= 768px) {
        .wheat-surplus-grain {
            height: 1rem;
        }
    }

    .wheat-surplus-grain--9 {
        width: 100%;
    }

    .wheat-surplus-grain--8 {
        width: 90%;
        background-color: rgb(146 64 14 / 0.3);
    }

    .wheat-surplus-grain--7 {
        width: 80%;
        background-color: rgb(146 64 14 / 0.4);
    }

    .wheat-surplus-grain--6 {
        width: 70%;
        background-color: rgb(146 64 14 / 0.5);
    }

    .wheat-surplus-grain--5 {
        width: 60%;
        background-color: rgb(146 64 14 / 0.6);
    }

    .wheat-surplus-grain--4 {
        width: 50%;
        background-color: rgb(146 64 14 / 0.7);
    }

    .wheat-surplus-grain--3 {
        width: 40%;
        background-color: rgb(146 64 14 / 0.8);
    }

    .wheat-surplus-grain--2 {
        width: 30%;
        background-color: rgb(146 64 14 / 0.9);
    }

    .wheat-surplus-grain--1 {
        width: 20%;
        background-color: var(--wheat-amber-800);
        box-shadow: 0 0 15px rgb(var(--wheat-amber-500-rgb) / 0.3);
    }

    .wheat-surplus-caption {
        top: 0.5rem;
        right: 0.5rem;
        font-size: 10px;
        color: rgb(var(--wheat-amber-500-rgb) / 0.5);
    }

    @media (width >= 768px) {
        .wheat-surplus-caption {
            top: 1rem;
            right: 1rem;
            font-size: 12px;
        }
    }

    .wheat-surplus-chapter {
        color: var(--wheat-stone-400);
    }

    .wheat-surplus-title {
        color: var(--wheat-stone-200);
    }

    .wheat-surplus-desc {
        color: var(--wheat-stone-300);
    }

    .wheat-surplus-strong {
        color: var(--wheat-white);
    }

    .wheat-surplus-card {
        background-color: var(--wheat-stone-800);
        border-color: rgb(146 64 14 / 0.1);
    }

    .wheat-surplus-card-title {
        color: var(--wheat-stone-400);
    }

    .wheat-surplus-card-desc {
        color: var(--wheat-stone-500);
    }
</style>
