---
import ShareableQuote from "./WheatShareableQuote.astro";

import type { WheatTexts } from "../../concepts/wheat/types";

interface Props {
    texts: WheatTexts["workHours"];
    common: WheatTexts["common"];
}

const { texts, common } = Astro.props;
---

<section
    id="jornada-laboral"
    class="wheat-relative wheat-font-serif wheat-min-h-screen wheat-flex wheat-items-center wheat-justify-center wheat-py-12 wheat-py-24@md wheat-workhours"
>
    <div class="wheat-container wheat-container--wide wheat-px-6 wheat-w-full">
        <div class="wheat-text-center wheat-mb-16">
            <span
                class="trigo-chapter wheat-workhours-chapter wheat-text-xs wheat-text-sm@md wheat-tracking-widest wheat-uppercase wheat-block wheat-mb-4"
            >
                {texts.chapter}
            </span>
            <h2 class="wheat-text-3xl wheat-text-5xl@md wheat-font-bold wheat-workhours-title mb-6">
                {texts.title}
            </h2>
            <p class="wheat-text-lg wheat-workhours-desc wheat-max-w-2xl wheat-mx-auto">
                <ShareableQuote quote={texts.quote} shareLabel={common.shareIdea} />
                {texts.description}
            </p>
        </div>

        <div class="wheat-grid wheat-grid--cols-2 wheat-items-end wheat-workhours-chart">
            <div
                class="wheat-flex wheat-flex-col wheat-justify-end wheat-h-full wheat-workhours-group"
            >
                <div class="wheat-mb-4 wheat-text-center wheat-workhours-tooltip">
                    <span
                        class="wheat-text-3xl wheat-font-bold wheat-workhours-val wheat-workhours-val--hunter"
                        >{texts.hunterHours}</span
                    >
                    <p
                        class="wheat-text-xs wheat-workhours-label wheat-workhours-label--hunter wheat-uppercase wheat-tracking-widest wheat-mt-1"
                    >
                        {texts.hunterMeasure}
                    </p>
                </div>
                <div
                    class="wheat-relative wheat-w-full wheat-workhours-bar wheat-workhours-bar--hunter"
                >
                    <div
                        class="wheat-absolute wheat-inset-0 wheat-workhours-bar-bg wheat-workhours-bar-bg--hunter"
                    >
                    </div>
                    <div
                        class="wheat-absolute wheat-workhours-bar-line wheat-workhours-bar-line--hunter"
                    >
                    </div>
                </div>
                <div class="wheat-mt-4 wheat-text-center">
                    <h3 class="wheat-text-xl wheat-font-bold wheat-workhours-group-title">
                        {texts.hunterTitle}
                    </h3>
                    <p class="wheat-text-sm wheat-workhours-group-desc wheat-mt-2">
                        {texts.hunterDescription}
                    </p>
                </div>
            </div>

            <div
                class="wheat-flex wheat-flex-col wheat-justify-end wheat-h-full wheat-workhours-group"
            >
                <div class="wheat-mb-4 wheat-text-center wheat-workhours-tooltip">
                    <span
                        class="wheat-text-3xl wheat-font-bold wheat-workhours-val wheat-workhours-val--farmer"
                        >{texts.farmerHours}</span
                    >
                    <p
                        class="wheat-text-xs wheat-workhours-label wheat-workhours-label--farmer wheat-uppercase wheat-tracking-widest wheat-mt-1"
                    >
                        {texts.farmerMeasure}
                    </p>
                </div>
                <div
                    class="wheat-relative wheat-w-full wheat-workhours-bar wheat-workhours-bar--farmer"
                >
                    <div
                        class="wheat-absolute wheat-inset-0 wheat-workhours-bar-bg wheat-workhours-bar-bg--farmer"
                    >
                    </div>
                    <div
                        class="wheat-absolute wheat-workhours-bar-line wheat-workhours-bar-line--farmer"
                    >
                    </div>
                    <div class="wheat-absolute wheat-inset-0 wheat-workhours-bar-overlay"></div>
                </div>
                <div class="wheat-mt-4 wheat-text-center">
                    <h3 class="wheat-text-xl wheat-font-bold wheat-workhours-group-title">
                        {texts.farmerTitle}
                    </h3>
                    <p class="wheat-text-sm wheat-workhours-group-desc wheat-mt-2">
                        {texts.farmerDescription}
                    </p>
                </div>
            </div>
        </div>

        <div class="wheat-mt-16 wheat-text-center">
            <p class="wheat-text-xs wheat-workhours-source wheat-italic">
                {texts.sourceNote}
            </p>
        </div>
    </div>
</section>

<style>
    .wheat-workhours {
        color: var(--wheat-stone-200);
    }

    .wheat-workhours-chapter {
        color: rgb(217 119 6 / 0.6);
    }

    .wheat-workhours-title {
        color: var(--wheat-stone-200);
    }

    .wheat-workhours-desc {
        color: var(--wheat-stone-400);
    }

    .wheat-workhours-chart {
        height: 50vh;
        align-items: flex-end;
    }

    @media (width >= 768px) {
        .wheat-workhours-chart {
            height: 400px;
        }
    }

    .wheat-workhours-group {
        height: 100%;
    }

    .wheat-workhours-tooltip {
        opacity: 0;
        transition: opacity 0.3s;
    }

    .wheat-workhours-group:hover .wheat-workhours-tooltip {
        opacity: 1;
    }

    .wheat-workhours-val--hunter {
        color: var(--wheat-emerald-400);
    }

    .wheat-workhours-val--farmer {
        color: var(--wheat-amber-500);
    }

    .wheat-workhours-label--hunter {
        color: rgb(var(--wheat-emerald-400-rgb) / 0.6);
    }

    .wheat-workhours-label--farmer {
        color: rgb(var(--wheat-amber-500-rgb) / 0.6);
    }

    .wheat-workhours-bar {
        background-color: var(--wheat-stone-800);
        border-top-left-radius: 0.5rem;
        border-top-right-radius: 0.5rem;
        overflow: hidden;
        transition: all 1s ease-out;
    }

    .wheat-workhours-group:hover .wheat-workhours-bar {
        background-color: var(--wheat-stone-700);
    }

    .wheat-workhours-bar--hunter {
        height: 35%;
    }

    .wheat-workhours-bar--farmer {
        height: 90%;
    }

    .wheat-workhours-bar-bg--hunter {
        background-color: rgb(6 95 70 / 0.2);
    }

    .wheat-workhours-bar-bg--farmer {
        background-color: rgb(146 64 14 / 0.2);
    }

    .wheat-workhours-bar-line--hunter {
        bottom: 0;
        left: 0;
        width: 100%;
        height: 1px;
        background-color: rgb(var(--wheat-emerald-400-rgb) / 0.5);
    }

    .wheat-workhours-bar-line--farmer {
        bottom: 0;
        left: 0;
        width: 100%;
        height: 1px;
        background-color: rgb(var(--wheat-amber-500-rgb) / 0.5);
    }

    .wheat-workhours-bar-overlay {
        opacity: 0.2;
        mix-blend-mode: overlay;
    }

    .wheat-workhours-group-title {
        color: var(--wheat-stone-200);
    }

    .wheat-workhours-group-desc {
        color: var(--wheat-stone-400);
    }

    .wheat-workhours-source {
        color: var(--wheat-stone-600);
    }
</style>
