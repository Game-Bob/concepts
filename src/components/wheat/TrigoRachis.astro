---
import ShareableQuote from "./WheatShareableQuote.astro";

import type { WheatTexts } from "../../concepts/wheat/types";

interface Props {
    texts: WheatTexts["rachis"];
    common: WheatTexts["common"];
}

const { texts, common } = Astro.props;
---

<section
    id="raquis"
    class="wheat-relative wheat-font-serif wheat-min-h-screen wheat-flex wheat-items-center wheat-justify-center wheat-py-12 wheat-py-24@md wheat-rachis"
>
    <div
        class="wheat-container wheat-container--wide wheat-grid wheat-grid--cols-2 wheat-items-center wheat-gap-8 wheat-gap-16@md"
    >
        <div
            class="wheat-rachis-visual wheat-flex wheat-items-center wheat-justify-center wheat-rounded wheat-overflow-hidden wheat-border"
        >
            <div class="wheat-absolute wheat-inset-0 wheat-rachis-visual-bg"></div>

            <div class="wheat-relative wheat-rachis-stem">
                <div class="wheat-absolute wheat-rachis-joint wheat-rachis-joint--top"></div>
                <div class="wheat-absolute wheat-rachis-joint wheat-rachis-joint--bottom"></div>
                <div class="wheat-absolute wheat-rachis-pulse wheat-rounded-full"></div>
                <div class="wheat-absolute wheat-rachis-dot wheat-rounded-full"></div>
            </div>

            <div class="wheat-absolute wheat-rachis-caption">
                <p class="wheat-text-xs wheat-tracking-widest wheat-uppercase">
                    {texts.chapter}
                </p>
            </div>
        </div>

        <div class="wheat-space-y-12 wheat-space-y-16@md">
            <div class="wheat-space-y-4 wheat-space-y-6@md">
                <span
                    class="trigo-chapter wheat-rachis-chapter wheat-text-xs wheat-text-sm@md wheat-tracking-widest wheat-uppercase"
                >
                    {texts.title}
                </span>
                <h2 class="wheat-text-3xl wheat-text-4xl@md wheat-font-bold wheat-rachis-title">
                    {texts.lead}
                </h2>
                <p class="wheat-text-base wheat-text-lg@md wheat-leading-relaxed wheat-rachis-desc">
                    {texts.explanationBeforeName}
                    <strong class="wheat-font-bold wheat-rachis-strong">{texts.chapter}</strong>{
                        texts.explanationAfterName
                    }
                </p>
                <p class="wheat-text-base wheat-text-lg@md wheat-leading-relaxed wheat-rachis-desc">
                    {texts.consequence}
                    <ShareableQuote quote={texts.quote} shareLabel={common.shareIdea} />
                </p>
            </div>
        </div>
    </div>
</section>

<style>
    .wheat-rachis {
        color: var(--wheat-stone-200);
    }

    .wheat-rachis-visual {
        height: 40vh;
        background-color: var(--wheat-stone-950);
        border-color: rgb(146 64 14 / 0.2);
        position: relative;
    }

    @media (width >= 768px) {
        .wheat-rachis-visual {
            height: 80vh;
            position: sticky;
            top: 2.5rem;
        }

        .wheat-gap-16\@md {
            gap: 4rem;
        }

        .wheat-space-y-6\@md > * + * {
            margin-top: 1.5rem;
        }

        .wheat-space-y-16\@md > * + * {
            margin-top: 4rem;
        }
    }

    .wheat-rachis-visual-bg {
        background: radial-gradient(
            circle at center,
            var(--wheat-stone-800),
            var(--wheat-stone-950)
        );
    }

    .wheat-rachis-stem {
        width: 0.5rem;
        height: 12rem;
        background-color: var(--wheat-stone-600);
        border-radius: 9999px;
    }

    @media (width >= 768px) {
        .wheat-rachis-stem {
            height: 16rem;
        }
    }

    .wheat-rachis-joint {
        left: 50%;
        transform: translateX(-50%);
        width: 2rem;
        height: 2rem;
        border-radius: 50%;
    }

    @media (width >= 768px) {
        .wheat-rachis-joint {
            width: 3rem;
            height: 3rem;
        }
    }

    .wheat-rachis-joint--top {
        top: 0;
        border-bottom: 4px solid var(--wheat-stone-400);
        transform: translateX(-50%) rotate(45deg);
    }

    .wheat-rachis-joint--bottom {
        bottom: 0;
        border-top: 4px solid var(--wheat-stone-400);
        transform: translateX(-50%) rotate(-45deg);
    }

    .wheat-rachis-pulse {
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 1.5rem;
        height: 1.5rem;
        background-color: rgb(120 53 4 / 0.5);
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        filter: blur(4px);
    }

    @media (width >= 768px) {
        .wheat-rachis-pulse {
            width: 2rem;
            height: 2rem;
        }
    }

    .wheat-rachis-dot {
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 0.375rem;
        height: 0.375rem;
        background-color: var(--wheat-amber-500);
    }

    @media (width >= 768px) {
        .wheat-rachis-dot {
            width: 0.5rem;
            height: 0.5rem;
        }
    }

    .wheat-rachis-caption {
        bottom: 1rem;
        width: 100%;
        text-align: center;
        box-sizing: border-box;
        padding: 0 1rem;
    }

    @media (width >= 768px) {
        .wheat-rachis-caption {
            bottom: 2rem;
        }
    }

    .wheat-rachis-caption p {
        color: rgb(var(--wheat-amber-500-rgb) / 0.8);
    }

    .wheat-rachis-chapter {
        color: var(--wheat-stone-400);
    }

    .wheat-rachis-title {
        color: var(--wheat-stone-200);
    }

    .wheat-rachis-desc {
        color: var(--wheat-stone-300);
    }

    .wheat-rachis-strong {
        color: var(--wheat-white);
    }

    @keyframes pulse {
        0%,
        100% {
            opacity: 1;
            transform: translate(-50%, -50%) scale(1);
        }

        50% {
            opacity: 0.5;
            transform: translate(-50%, -50%) scale(0.85);
        }
    }
</style>
