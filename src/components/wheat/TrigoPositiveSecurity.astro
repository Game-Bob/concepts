---
import ShareableQuote from "./WheatShareableQuote.astro";

import type { WheatTexts } from "../../concepts/wheat/types";

interface Props {
    texts: WheatTexts["positiveSecurity"];
    common: WheatTexts["common"];
}

const { texts, common } = Astro.props;
---

<section
    id="positive-security"
    class="wheat-relative wheat-font-serif wheat-min-h-screen wheat-flex wheat-items-center wheat-justify-center wheat-py-12 wheat-py-24@md wheat-pos-security"
>
    <div
        class="wheat-container wheat-container--wide wheat-px-6 wheat-grid wheat-grid--cols-2 wheat-items-center wheat-gap-16"
    >
        <div class="wheat-pos-security-content wheat-space-y-6">
            <span
                class="wheat-text-xs wheat-text-sm@md wheat-tracking-widest wheat-uppercase wheat-block trigo-positive-chapter"
            >
                {texts.chapter}
            </span>
            <h2 class="wheat-text-3xl wheat-text-5xl@md wheat-font-bold wheat-pos-security-title">
                {texts.title}
            </h2>
            <p class="wheat-text-lg wheat-leading-relaxed wheat-pos-security-desc-primary">
                {texts.firstParagraph}
                <strong class="wheat-font-bold wheat-pos-security-strong">{texts.emphasis}</strong>.
            </p>
            <p class="wheat-text-base wheat-leading-relaxed wheat-pos-security-desc-secondary">
                {texts.secondParagraph}
                <ShareableQuote quote={texts.quote} shareLabel={common.shareIdea} />
            </p>

            <div class="wheat-grid wheat-grid--cols-3 wheat-gap-4 wheat-pt-4">
                <div
                    class="wheat-text-center wheat-p-4 wheat-pos-security-stat-card wheat-rounded-lg wheat-border"
                >
                    <div
                        class="wheat-text-2xl wheat-font-bold wheat-pos-security-stat-val wheat-mb-1"
                    >
                        {texts.metrics[0].value}
                    </div>
                    <div
                        class="wheat-text-xs wheat-pos-security-stat-label wheat-uppercase wheat-tracking-widest"
                    >
                        {texts.metrics[0].label}
                    </div>
                </div>
                <div
                    class="wheat-text-center wheat-p-4 wheat-pos-security-stat-card wheat-rounded-lg wheat-border"
                >
                    <div
                        class="wheat-text-2xl wheat-font-bold wheat-pos-security-stat-val wheat-mb-1"
                    >
                        0
                    </div>
                    <div
                        class="wheat-text-xs wheat-pos-security-stat-label wheat-uppercase wheat-tracking-widest"
                    >
                        {texts.metrics[1].label}
                    </div>
                </div>
                <div
                    class="wheat-text-center wheat-p-4 wheat-pos-security-stat-card wheat-rounded-lg wheat-border"
                >
                    <div
                        class="wheat-text-2xl wheat-font-bold wheat-pos-security-stat-val wheat-mb-1"
                    >
                        100%
                    </div>
                    <div
                        class="wheat-text-xs wheat-pos-security-stat-label wheat-uppercase wheat-tracking-widest"
                    >
                        {texts.metrics[2].label}
                    </div>
                </div>
            </div>
        </div>

        <div
            class="wheat-relative wheat-pos-security-visual-col wheat-flex wheat-items-center wheat-justify-center"
        >
            <div class="wheat-absolute wheat-inset-0 wheat-pos-security-radial-glow"></div>

            <div class="wheat-relative wheat-pos-security-card-container">
                <div class="wheat-absolute wheat-pos-security-blur-glow wheat-rounded-full"></div>

                <div
                    class="wheat-relative wheat-pos-security-visual-card wheat-rounded-2xl wheat-border wheat-p-8 wheat-overflow-hidden"
                >
                    <div class="wheat-absolute wheat-pos-security-visual-card-line"></div>

                    <div
                        class="wheat-relative wheat-pos-security-visual-card-content wheat-space-y-6"
                    >
                        <div
                            class="wheat-flex wheat-items-center wheat-justify-between wheat-pos-security-capacity wheat-text-sm"
                        >
                            <span>{texts.capacityLabel}</span>
                            <span>100%</span>
                        </div>

                        <div class="wheat-space-y-3">
                            <div
                                class="wheat-relative wheat-pos-security-bar wheat-rounded-lg wheat-overflow-hidden"
                            >
                                <div
                                    class="wheat-absolute wheat-pos-security-bar-fill wheat-pos-security-bar-fill--1"
                                >
                                </div>
                                <div
                                    class="wheat-absolute wheat-inset-0 wheat-flex wheat-items-center wheat-justify-center"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke-width="1.5"
                                        stroke="currentColor"
                                        class="wheat-pos-security-bar-icon"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"
                                        ></path>
                                    </svg>
                                </div>
                            </div>
                            <div
                                class="wheat-relative wheat-pos-security-bar wheat-rounded-lg wheat-overflow-hidden"
                            >
                                <div
                                    class="wheat-absolute wheat-pos-security-bar-fill wheat-pos-security-bar-fill--2"
                                >
                                </div>
                                <div
                                    class="wheat-absolute wheat-inset-0 wheat-flex wheat-items-center wheat-justify-center"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke-width="1.5"
                                        stroke="currentColor"
                                        class="wheat-pos-security-bar-icon"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"
                                        ></path>
                                    </svg>
                                </div>
                            </div>
                            <div
                                class="wheat-relative wheat-pos-security-bar wheat-rounded-lg wheat-overflow-hidden"
                            >
                                <div
                                    class="wheat-absolute wheat-pos-security-bar-fill wheat-pos-security-bar-fill--3"
                                >
                                </div>
                                <div
                                    class="wheat-absolute wheat-inset-0 wheat-flex wheat-items-center wheat-justify-center"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke-width="1.5"
                                        stroke="currentColor"
                                        class="wheat-pos-security-bar-icon"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"
                                        ></path>
                                    </svg>
                                </div>
                            </div>
                        </div>

                        <div class="wheat-pt-4 wheat-pos-security-visual-footer wheat-text-center">
                            <div
                                class="wheat-text-xs wheat-uppercase wheat-tracking-widest wheat-pos-security-reserve-label wheat-mb-2"
                            >
                                {texts.reserveLabel}
                            </div>
                            <div
                                class="wheat-text-2xl wheat-font-bold wheat-pos-security-reserve-value"
                            >
                                {texts.granaryLabel}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .wheat-pos-security {
        color: var(--wheat-stone-200);
        border-bottom: 1px solid rgb(var(--wheat-emerald-500-rgb) / 0.1);
    }

    .wheat-pos-security-title {
        color: var(--wheat-stone-200);
    }

    .wheat-pos-security-desc-primary {
        color: var(--wheat-stone-300);
    }

    .wheat-pos-security-strong {
        color: var(--wheat-emerald-500);
    }

    .wheat-pos-security-desc-secondary {
        color: var(--wheat-stone-400);
    }

    .wheat-pos-security-stat-card {
        background-color: var(--wheat-stone-900);
        border-color: rgb(var(--wheat-emerald-500-rgb) / 0.2);
    }

    .wheat-pos-security-stat-val {
        color: var(--wheat-emerald-500);
    }

    .wheat-pos-security-stat-label {
        color: var(--wheat-stone-400);
    }

    .wheat-pos-security-visual-col {
        height: 500px;
    }

    .wheat-pos-security-radial-glow {
        background: radial-gradient(
            circle at center,
            rgb(var(--wheat-emerald-500-rgb) / 0.2),
            transparent,
            transparent
        );
    }

    .wheat-pos-security-card-container {
        width: 100%;
        max-width: 300px;
    }

    .wheat-pos-security-blur-glow {
        inset: 0;
        background-color: rgb(var(--wheat-emerald-500-rgb) / 0.1);
        filter: blur(24px);
    }

    .wheat-pos-security-visual-card {
        background: linear-gradient(to bottom, var(--wheat-stone-900), var(--wheat-stone-950));
        border-color: rgb(var(--wheat-emerald-500-rgb) / 0.3);
    }

    .wheat-pos-security-visual-card-line {
        height: 1px;
        background: linear-gradient(
            to right,
            transparent,
            rgb(var(--wheat-emerald-500-rgb) / 0.5),
            transparent
        );
        top: 0;
        left: 0;
        right: 0;
    }

    .wheat-pos-security-visual-card-content {
        z-index: 10;
    }

    .wheat-pos-security-capacity {
        color: rgb(var(--wheat-emerald-500-rgb) / 0.6);
    }

    .wheat-pos-security-bar {
        height: 3rem;
        background-color: rgb(var(--wheat-emerald-500-rgb) / 0.2);
    }

    .wheat-pos-security-bar-fill {
        background: linear-gradient(
            to right,
            rgb(var(--wheat-emerald-500-rgb) / 0.4),
            rgb(5 150 105 / 0.4)
        );
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        height: 100%;
    }

    .wheat-pos-security-bar-fill--1 {
        width: 85%;
    }

    .wheat-pos-security-bar-fill--2 {
        width: 92%;
        animation-delay: 0.3s;
    }

    .wheat-pos-security-bar-fill--3 {
        width: 78%;
        animation-delay: 0.6s;
    }

    .wheat-pos-security-bar-icon {
        width: 1.5rem;
        height: 1.5rem;
        color: var(--wheat-emerald-400);
    }

    .wheat-pos-security-visual-footer {
        border-top: 1px solid rgb(var(--wheat-emerald-500-rgb) / 0.2);
    }

    .wheat-pos-security-reserve-label {
        color: rgb(var(--wheat-emerald-500-rgb) / 0.6);
    }

    .wheat-pos-security-reserve-value {
        color: var(--wheat-emerald-400);
    }

    @keyframes pulse {
        0%,
        100% {
            opacity: 1;
        }

        50% {
            opacity: 0.5;
        }
    }

    @media (width >= 768px) {
        .wheat-pos-security-content {
            order: 1;
        }

        .wheat-pos-security-visual-col {
            order: 2;
        }

        .wheat-space-y-6 > * + * {
            margin-top: 1.5rem;
        }

        .wheat-grid--cols-3 {
            grid-template-columns: repeat(3, 1fr);
        }
    }
</style>
