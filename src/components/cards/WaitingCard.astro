---
import type { WaitingLocaleData } from "../../concepts/waiting/locales";
import "../../styles/cards/waiting-card.css";

interface Props {
    href: string;
    locale: WaitingLocaleData;
    number: string;
}
const { href, locale, number } = Astro.props;
---

<a class="waiting-card" href={href}>
    <span class="waiting-card__number">{number}</span>
    <div class="waiting-card__copy">
        <p>{locale.cardSubtitle}</p>
        <h2>{locale.cardTitle}</h2>
    </div>
    <div class="waiting-card__stage" aria-hidden="true">
        <span class="waiting-card__orbit"></span>
        <svg viewBox="0 0 100 120" class="waiting-card__hourglass">
            <defs>
                <clipPath id="top-sand-clip">
                    <path d="M 32,23 L 68,23 C 68,40 57,54 53,58 L 47,58 C 43,54 32,40 32,23 Z"
                    ></path>
                </clipPath>
                <clipPath id="bottom-sand-clip">
                    <path d="M 47,62 L 53,62 C 57,66 68,80 68,97 L 32,97 C 32,80 43,66 47,62 Z"
                    ></path>
                </clipPath>
            </defs>

            <path
                d="M 30,20 L 70,20 C 70,40 58,55 54,60 C 58,65 70,80 70,100 L 30,100 C 30,80 42,65 46,60 C 42,55 30,40 30,20 Z"
                fill="none"
                stroke="var(--waiting-card-accent)"
                stroke-width="2"
                stroke-linejoin="round"
                opacity="0.8"></path>
            <rect x="25" y="14" width="50" height="6" rx="2" fill="var(--waiting-card-accent)"
            ></rect>
            <rect x="25" y="100" width="50" height="6" rx="2" fill="var(--waiting-card-accent)"
            ></rect>

            <g clip-path="url(#top-sand-clip)">
                <rect
                    x="20"
                    y="20"
                    width="60"
                    height="40"
                    fill="var(--waiting-card-accent)"
                    class="sand-top-drain"></rect>
            </g>

            <g class="sand-stream-container">
                <line
                    x1="50"
                    y1="58"
                    x2="50"
                    y2="95"
                    stroke="var(--waiting-card-accent)"
                    stroke-width="1.5"
                    class="sand-stream-fall"></line>
            </g>

            <g clip-path="url(#bottom-sand-clip)">
                <rect
                    x="20"
                    y="60"
                    width="60"
                    height="40"
                    fill="var(--waiting-card-accent)"
                    class="sand-bottom-fill"></rect>
            </g>
        </svg>
        <span class="waiting-card__shadow"></span>
    </div>
    <div class="waiting-card__footer">
        <span></span>
        <blockquote>{locale.cardDescription}</blockquote>
    </div>
    <span class="waiting-card__border" aria-hidden="true"></span>
</a>
