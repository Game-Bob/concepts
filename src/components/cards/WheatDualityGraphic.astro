---
import { Icon } from "astro-icon/components";

interface Props {
    leftLabel: string;
    rightLabel: string;
}

const { leftLabel, rightLabel } = Astro.props;
---

<div class="wheat-card__duality" aria-hidden="true">
    <div class="wheat-card__side wheat-card__side--freedom">
        <div class="wheat-card__glow wheat-card__glow--freedom"></div>
        <svg viewBox="0 0 180 220" preserveAspectRatio="none" class="wheat-card__svg">
            <path
                class="wheat-card__horizon"
                d="M 0 160 C 35 130 60 170 95 140 C 130 110 155 135 180 100"></path>
            <path class="wheat-card__wind-1" d="M 5 50 C 45 25 75 60 115 35 C 140 20 160 25 180 15"
            ></path>
            <path class="wheat-card__wind-2" d="M 0 95 C 40 70 70 105 110 80 C 135 65 155 70 180 60"
            ></path>
            <path class="wheat-card__spear" d="M 55 45 L 55 175 M 46 62 L 55 45 L 64 62"></path>
        </svg>
        <span class="wheat-card__label">{leftLabel}</span>
    </div>

    <div class="wheat-card__side wheat-card__side--security">
        <div class="wheat-card__glow wheat-card__glow--security"></div>
        <svg viewBox="0 0 180 220" preserveAspectRatio="none" class="wheat-card__svg">
            <path
                d="M 0 50 H 180 M 0 90 H 180 M 0 130 H 180 M 0 170 H 180 M 0 210 H 180"
                class="wheat-card__grid-h"></path>
            <path
                d="M 30 50 V 90 M 110 50 V 90 M 70 90 V 130 M 150 90 V 130 M 30 130 V 170 M 110 130 V 170 M 70 170 V 210 M 150 170 V 210"
                class="wheat-card__grid-v"></path>
            <path
                class="wheat-card__granary"
                d="M 60 70 L 90 40 L 120 70 V 160 H 60 Z M 90 40 V 160"></path>
        </svg>
        <span class="wheat-card__label">{rightLabel}</span>
    </div>

    <div class="wheat-card__axis"></div>
    <div class="wheat-card__pivot">
        <div class="wheat-card__pivot-ring"></div>
        <Icon name="mdi:barley" class="wheat-card__pivot-icon" />
    </div>
</div>
