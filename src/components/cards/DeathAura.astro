<div class="library-card__aura" aria-hidden="true">
    <img src="/images/death-reading.webp" class="library-card__aura-mist-outer" alt="" />
    <img src="/images/death-reading.webp" class="library-card__aura-mist-inner" alt="" />
</div>

<style>
    .library-card__aura {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 1;
    }

    .library-card__aura-mist-inner,
    .library-card__aura-mist-outer {
        position: absolute;
        bottom: -1.5rem;
        right: -6.5rem;
        height: 115%;
        width: auto;
        object-fit: contain;
        transform: scaleX(-1) scale(1);
        transform-origin: center center;
        pointer-events: none;
        filter: brightness(0) blur(30px);
        opacity: 0;
        visibility: hidden;
    }

    .library-card__aura-mist-inner {
        filter: brightness(0) blur(35px) drop-shadow(0 0 40px rgb(0 0 0 / 1));
        transition:
            transform 10s cubic-bezier(0.08, 0.8, 0.1, 1),
            filter 10s cubic-bezier(0.08, 0.8, 0.1, 1),
            opacity 6s ease-out,
            visibility 6s;
    }

    .library-card__aura-mist-outer {
        filter: brightness(0) blur(60px) drop-shadow(0 0 100px rgb(0 0 0 / 0.95));
        transition:
            transform 14s cubic-bezier(0.05, 0.85, 0.1, 1),
            filter 14s cubic-bezier(0.05, 0.85, 0.1, 1),
            opacity 8s ease-out,
            visibility 8s;
    }

    :global(.library-card:hover) .library-card__aura-mist-inner {
        opacity: 0.95;
        visibility: visible;
        transform: scaleX(-1) scale(6);
        filter: brightness(0) blur(70px) drop-shadow(0 0 200px rgb(0 0 0 / 1));
    }

    :global(.library-card:hover) .library-card__aura-mist-outer {
        opacity: 0.95;
        visibility: visible;
        transform: scaleX(-1) scale(12);
        filter: brightness(0) blur(120px) drop-shadow(0 0 500px rgb(0 0 0 / 1));
    }
</style>
