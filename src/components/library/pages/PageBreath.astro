---
interface Props {
    side: "left" | "right";
    texts: {
        title: string;
        sublabel: string;
        quote: string;
    };
}
const { side, texts } = Astro.props;
---

{
    side === "left" ? (
        <div class="lb-page-visual-container">
            <div class="lb-page-breath-wrapper">
                <div class="lb-page-breath-glow-base" />
                <div class="lb-page-breath-center">
                    <div class="lb-page-breath-c1" />
                    <div class="lb-page-breath-c2" />
                    <div class="lb-page-breath-c3" />
                    <div class="lb-page-breath-c4" />
                    <div class="lb-page-breath-orbit">
                        <div class="lb-page-breath-orbit-dot dot-1" />
                        <div class="lb-page-breath-orbit-dot dot-2" />
                        <div class="lb-page-breath-orbit-dot dot-3" />
                    </div>
                </div>
            </div>
        </div>
    ) : (
        <div class="lb-page-text-container">
            <h3 class="lb-page-title-colored lb-page-title-blue">{texts.title}</h3>

            <div>
                <div class="lb-page-counter-small" id="breath-counter">
                    0
                </div>
                <div class="lb-page-counter-label">{texts.sublabel}</div>
            </div>

            <p class="lb-page-quote">{texts.quote}</p>
        </div>
    )
}

<style>
    .lb-page-breath-wrapper {
        position: relative;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .lb-page-breath-glow-base {
        position: absolute;
        inset: 0;
        background-image: linear-gradient(
            to bottom,
            transparent,
            rgb(30 58 138 / 0.05),
            transparent
        );
        filter: blur(20px);
        pointer-events: none;
    }

    .lb-page-breath-center {
        position: relative;
        width: 12rem;
        height: 12rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .lb-page-breath-c1,
    .lb-page-breath-c2,
    .lb-page-breath-c3,
    .lb-page-breath-c4 {
        position: absolute;
        border-radius: 9999px;
        border: 1px solid rgb(59 130 246 / 0.15);
        background-color: rgb(59 130 246 / 0.02);
    }

    .lb-page-breath-c1 {
        width: 100%;
        height: 100%;
        animation: lb-breath-pulse 4s ease-in-out infinite;
    }

    .lb-page-breath-c2 {
        width: 75%;
        height: 75%;
        animation: lb-breath-pulse 4s ease-in-out infinite;
        animation-delay: 0.5s;
    }

    .lb-page-breath-c3 {
        width: 50%;
        height: 50%;
        animation: lb-breath-pulse 4s ease-in-out infinite;
        animation-delay: 1s;
    }

    .lb-page-breath-c4 {
        width: 25%;
        height: 25%;
        animation: lb-breath-pulse 4s ease-in-out infinite;
        animation-delay: 1.5s;
        background-color: rgb(59 130 246 / 0.05);
        border: 1px solid rgb(59 130 246 / 0.3);
    }

    .lb-page-breath-orbit {
        position: absolute;
        width: 110%;
        height: 110%;
        border: 1px dashed rgb(59 130 246 / 0.08);
        border-radius: 9999px;
        animation: lb-spin 20s linear infinite;
    }

    .lb-page-breath-orbit-dot {
        position: absolute;
        width: 6px;
        height: 6px;
        background-color: rgb(96 165 250 / 0.4);
        border-radius: 9999px;
    }

    .lb-page-breath-orbit-dot.dot-1 {
        top: 0;
        left: 50%;
        transform: translate(-50%, -50%);
    }

    .lb-page-breath-orbit-dot.dot-2 {
        bottom: 25%;
        left: 6.7%;
    }

    .lb-page-breath-orbit-dot.dot-3 {
        bottom: 25%;
        right: 6.7%;
    }

    @keyframes lb-breath-pulse {
        0%,
        100% {
            transform: scale(0.9);
            opacity: 0.3;
        }

        50% {
            transform: scale(1.1);
            opacity: 0.8;
            border-color: rgb(59 130 246 / 0.3);
            background-color: rgb(59 130 246 / 0.04);
            box-shadow: 0 0 20px rgb(59 130 246 / 0.1);
        }
    }

    @keyframes lb-spin {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }
</style>

<script>
    import { getLifeStatsUpdate } from "../../../utils/libraryLogic";

    const counter = document.getElementById("breath-counter");
    let animationFrame: number;

    document.addEventListener("update-life-stats", (event) => {
        const { birthdate } = getLifeStatsUpdate(event);
        if (!counter) return;

        const start = () => {
            const now = new Date();
            const msAlive = now.getTime() - new Date(birthdate).getTime();
            const preciseBreaths = msAlive * (16 / 60000);
            counter.innerText = Math.floor(preciseBreaths).toLocaleString();
            animationFrame = requestAnimationFrame(start);
        };

        if (animationFrame) cancelAnimationFrame(animationFrame);
        start();
    });
</script>
