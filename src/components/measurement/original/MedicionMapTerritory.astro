---
import type { MeasurementTexts } from "../../../concepts/measurement/locales";

interface Props {
    texts: MeasurementTexts;
}

const { texts } = Astro.props;
---

<section class="med-section med-section-local">
    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <h2 class="med-title med-title-local">
                    {texts["mapTerritory.001"]}
                </h2>

                <p class="med-text-lg medicion-map-body">
                    {texts["mapTerritory.002"]}
                </p>
                <p class="med-text-lg medicion-map-body">
                    {texts["mapTerritory.003"]}
                </p>

                <div class="med-space-y-4 med-mt-8">
                    <div class="med-card--left-border medicion-map-card">
                        <p class="med-card-text med-card-text-local">
                            <strong>{texts["mapTerritory.004"]}</strong>
                            {texts["mapTerritory.005"]}
                        </p>
                    </div>
                </div>
            </div>

            <div class="med-w-full medicion-map-visual-col med-flex med-justify-center">
                <div class="med-relative medicion-map-sizer">
                    <div class="med-absolute med-inset-0 medicion-map-bg"></div>
                    <div class="med-absolute med-inset-0 medicion-map-overlay"></div>

                    <div class="med-absolute med-inset-0 medicion-map-grid-overlay">
                        <div class="med-grid-cols-4 medicion-map-grid-inner">
                            {
                                Array.from({ length: 16 }).map((_) => (
                                    <div class="medicion-map-grid-cell" />
                                ))
                            }
                        </div>
                        <div class="med-absolute med-bottom-2 med-right-2 medicion-map-model-badge">
                            {texts["mapTerritory.006"]}
                        </div>
                    </div>

                    <div class="med-absolute medicion-map-label">
                        {texts["mapTerritory.007"]}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #1c1917;
        color: #e7e5e4;
    }

    .med-title-local {
        color: #fafaf9;
    }

    .med-card-text-local {
        color: #d6d3d1;
    }

    .medicion-map-body {
        line-height: 1.625;
        font-family: Georgia, "Times New Roman", serif;
        color: #a8a29e;
    }

    .medicion-map-card {
        background-color: #292524;
        padding: 1.5rem;
        border-left: 2px solid #ea580c;
    }

    .medicion-map-visual-col {
        width: 100%;
    }
    @media (min-width: 768px) {
        .medicion-map-visual-col {
            width: 50%;
        }
    }

    .medicion-map-sizer {
        position: relative;
        width: 16rem;
        height: 16rem;
    }
    @media (min-width: 768px) {
        .medicion-map-sizer {
            width: 20rem;
            height: 20rem;
        }
    }

    .medicion-map-bg {
        background-image: url("https://images.unsplash.com/photo-1478760329108-5c3ed9d495a0?q=80&w=1000&auto=format&fit=crop");
        background-size: cover;
        background-position: center;
        border-radius: 0.5rem;
        opacity: 0.4;
        filter: grayscale(100%);
        transform: rotateX(20deg) scale(0.9);
    }

    .medicion-map-overlay {
        background: linear-gradient(to top, #1c1917, transparent);
        border-radius: 0.5rem;
    }

    .medicion-map-grid-overlay {
        border: 2px solid #ea580c;
        background-color: rgba(234, 88, 12, 0.1);
        border-radius: 0.5rem;
        transform: translateY(-2rem) translateX(-1rem);
        display: flex;
        align-items: center;
        justify-content: center;
        -webkit-backdrop-filter: blur(4px);
        backdrop-filter: blur(4px);
        transition: transform 0.5s;
    }
    .medicion-map-grid-overlay:hover {
        transform: translateY(-3rem) translateX(-1.5rem);
    }

    .medicion-map-grid-inner {
        display: grid;
        grid-template-rows: repeat(4, 1fr);
        gap: 1rem;
        width: 100%;
        height: 100%;
        padding: 1rem;
    }

    .medicion-map-grid-cell {
        border: 1px solid rgba(234, 88, 12, 0.3);
    }

    .medicion-map-model-badge {
        font-size: 10px;
        font-family: monospace;
        color: #ea580c;
        background-color: rgba(0, 0, 0, 0.8);
        padding: 0 0.5rem;
    }

    .medicion-map-label {
        bottom: -2rem;
        left: 0;
        right: 0;
        text-align: center;
        font-size: 0.75rem;
        font-family: monospace;
        color: #57534e;
    }
</style>
