---
import type { MeasurementTexts } from "../../../concepts/measurement/locales";

interface Props {
    texts: MeasurementTexts;
}

const { texts } = Astro.props;
---

<section class="med-section med-section-local">
    <div
        class="med-absolute med-inset-0"
        style="background-image: linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 50px 50px;"
    >
    </div>

    <div class="med-container">
        <div class="med-mb-24 med-text-center med-max-w-4xl med-mx-auto">
            <span
                class="med-text-cyan-500 med-font-mono med-text-xs med-tracking-widest med-uppercase med-mb-4 med-block"
                >{texts["standardization.001"]}</span
            >
            <h2 class="med-text-5xl med-text-7xl@md med-font-bold med-tracking-tight med-mb-8">
                {texts["standardization.002"]}
            </h2>
            <p class="med-text-xl med-text-neutral-400 med-leading-relaxed">
                {texts["standardization.003"]}
                <br />
                <span class="med-text-white">{texts["standardization.004"]}</span>
            </p>
        </div>

        <div class="med-grid-cols-1 med-grid-cols-2@md med-gap-20 med-items-center">
            <div class="med-order-2 med-order-1@md med-relative">
                <div
                    class="med-relative med-card-prototype med-w-full med-rounded-sm med-shadow-2xl med-flex med-flex-col med-items-center med-justify-center med-overflow-hidden med-group med-transition-colors med-duration-500 med-p-8"
                >
                    <div
                        class="med-relative med-w-full med-meter-bar med-mb-12 med-child-scale med-transition-transform med-duration-700 med-rounded-sm med-meter-bar-shine"
                        style="background-image: linear-gradient(to bottom, #d4d4d4, #f5f5f5, #a3a3a3); box-shadow: 0 10px 20px rgba(0,0,0,0.5);"
                    >
                        <div
                            class="med-absolute med-inset-0 animate-shine"
                            style="background-image: linear-gradient(45deg, transparent 25%, rgba(255,255,255,0.5) 50%, transparent 75%); background-size: 250% 250%;"
                        >
                        </div>
                    </div>

                    <div class="med-space-y-4 med-text-center">
                        <div
                            class="med-text-xs med-font-mono med-text-neutral-500 med-tracking-widest med-uppercase"
                        >
                            {texts["standardization.005"]}
                        </div>
                        <div class="med-text-4xl med-font-bold med-font-serif med-text-white">
                            {texts["standardization.006"]}
                        </div>
                        <p class="med-text-sm med-text-neutral-400 med-max-w-xs med-mx-auto">
                            {texts["standardization.007"]}
                        </p>
                    </div>
                </div>

                <div
                    class="med-mt-8 med-p-6 med-border med-rounded med-text-sm med-leading-relaxed med-irony-card"
                >
                    <strong>{texts["standardization.008"]}</strong>
                    {texts["standardization.009"]}
                    <br />
                    <span class="med-italic med-opacity-70">{texts["standardization.010"]}</span>
                </div>
            </div>

            <div class="med-order-1 med-order-2@md med-space-y-10">
                <div>
                    <h3 class="med-text-2xl med-font-bold med-text-white med-mb-4">
                        {texts["standardization.011"]}
                    </h3>
                    <p class="med-text-neutral-400 med-leading-relaxed">
                        {texts["standardization.012"]}
                        <strong>{texts["standardization.013"]}</strong>
                    </p>
                </div>

                <div class="med-relative med-pl-8 med-border-l-2 med-border-neutral-700">
                    <div class="med-absolute med-dot-local-med med-rounded-full med-bg-neutral-700">
                    </div>
                    <p class="med-text-neutral-300 med-italic med-mb-2">
                        {texts["standardization.014"]}
                    </p>
                    <p class="med-text-sm med-text-neutral-500 med-leading-relaxed">
                        {texts["standardization.015"]}
                        <strong>{texts["standardization.016"]}</strong>
                        {texts["standardization.017"]}
                    </p>
                </div>

                <div>
                    <h3 class="med-text-2xl med-font-bold med-text-white med-mb-4">
                        {texts["standardization.018"]}
                    </h3>
                    <ul class="med-space-y-4 med-font-mono med-text-sm med-text-neutral-400">
                        <li
                            class="med-flex med-items-center med-gap-4 med-p-3 med-rounded med-transition-colors med-metric-row"
                        >
                            <span class="med-text-cyan-500 med-font-bold"
                                >{texts["standardization.019"]}</span
                            >
                            <span>{texts["standardization.020"]}</span>
                        </li>
                        <li
                            class="med-flex med-items-center med-gap-4 med-p-3 med-rounded med-transition-colors med-metric-row"
                        >
                            <span class="med-text-cyan-500 med-font-bold"
                                >{texts["standardization.021"]}</span
                            >
                            <span>{texts["standardization.022"]}</span>
                        </li>
                        <li
                            class="med-flex med-items-center med-gap-4 med-p-3 med-rounded med-transition-colors med-metric-row"
                        >
                            <span class="med-text-cyan-500 med-font-bold"
                                >{texts["standardization.023"]}</span
                            >
                            <span>{texts["standardization.024"]}</span>
                        </li>
                    </ul>
                    <p class="med-mt-4 med-text-xs med-text-neutral-600">
                        {texts["standardization.025"]}
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #171717;
        color: #ffffff;
    }

    .med-text-cyan-500 {
        color: #06b6d4;
    }
    .med-text-white {
        color: #ffffff;
    }
    .med-text-neutral-300 {
        color: #d4d4d4;
    }
    .med-text-neutral-400 {
        color: #a3a3a3;
    }
    .med-text-neutral-500 {
        color: #737373;
    }
    .med-text-neutral-600 {
        color: #525252;
    }
    .med-border-neutral-700 {
        border-color: #404040;
    }
    .med-bg-neutral-700 {
        background-color: #404040;
    }
    .med-max-w-4xl {
        max-width: 56rem;
    }
    .med-max-w-xs {
        max-width: 20rem;
    }
    .med-order-1 {
        order: 1;
    }
    .med-order-2 {
        order: 2;
    }
    @media (min-width: 768px) {
        .med-order-1\@md {
            order: 1;
        }
        .med-order-2\@md {
            order: 2;
        }
    }
    .med-card-prototype {
        height: 20rem;
        background-color: #262626;
        border-color: #525252;
    }
    .med-card-prototype:hover {
        border-color: #06b6d4;
    }
    .med-group:hover .med-child-scale {
        transform: scale(1.05);
    }
    .med-meter-bar {
        height: 2rem;
    }
    .med-meter-bar-shine {
        overflow: hidden;
    }
    .med-dot-local-med {
        left: -9px;
        top: 0;
        width: 1rem;
        height: 1rem;
    }
    .med-irony-card {
        background-color: rgba(21, 94, 117, 0.1);
        border-color: rgba(21, 94, 117, 0.3);
        color: rgba(165, 243, 252, 0.8);
    }
    .med-metric-row {
        background-color: rgba(38, 38, 38, 0.5);
    }
    .med-metric-row:hover {
        background-color: #262626;
    }

    @keyframes shine {
        0% {
            background-position: 200% 0;
        }
        100% {
            background-position: -200% 0;
        }
    }
    .animate-shine {
        animation: shine 3s infinite linear;
    }
</style>
