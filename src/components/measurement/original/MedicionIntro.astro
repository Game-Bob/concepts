---
import type { MeasurementTexts } from "../../../concepts/measurement/locales";

interface Props {
    texts: MeasurementTexts;
}

const { texts } = Astro.props;
---

<div class="med-intro">
    <div class="med-intro-bg"></div>

    <svg class="med-intro-grid" xmlns="http://www.w3.org/2000/svg">
        <defs>
            <pattern id="introGrid" width="40" height="40" patternUnits="userSpaceOnUse">
                <path d="M 40 0 L 0 0 0 40" fill="none" stroke="currentColor" stroke-width="0.5"
                ></path>
            </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#introGrid)"></rect>
    </svg>

    <div class="med-intro-content">
        <h1 class="med-intro-title">
            {texts["intro.001"]}
        </h1>

        <div class="med-intro-divider"></div>

        <div class="med-intro-texts">
            <p class="med-intro-text med-intro-text--large med-intro-text--muted med-delay-600">
                {texts["intro.002"]}
                <br />
                {texts["intro.003"]}
            </p>

            <p class="med-intro-text med-intro-text--muted med-delay-800">
                {texts["intro.004"]}
            </p>

            <p class="med-intro-text med-intro-text--muted med-delay-1000">
                {texts["intro.005"]}
                <span class="med-block med-mt-4 med-intro-text--white med-italic med-font-serif"
                    >{texts["intro.006"]}</span
                >
            </p>
        </div>
    </div>

    <div class="med-intro-scroll">
        <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
    </div>
</div>
