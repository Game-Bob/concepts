---
import type { MeasurementTexts } from "../../../concepts/measurement/locales";

interface Props {
    texts: MeasurementTexts;
}

const { texts } = Astro.props;
---

<section class="medicion-modern-section">
    <div
        class="med-absolute med-inset-0 medicion-modern-data-bg med-overflow-hidden med-pointer-events-none"
    >
        <div class="data-stream" style="left: 10%">{texts["modern.001"]}</div>
        <div class="data-stream" style="left: 30%; animation-delay: 1s">{texts["modern.002"]}</div>
        <div class="data-stream" style="left: 50%; animation-delay: 2s">{texts["modern.003"]}</div>
        <div class="data-stream" style="left: 70%; animation-delay: 0.5s">
            {texts["modern.004"]}
        </div>
        <div class="data-stream" style="left: 90%; animation-delay: 1.5s">
            {texts["modern.005"]}
        </div>
    </div>

    <div class="med-container">
        <div class="med-mb-32 medicion-modern-intro med-mx-auto med-text-center">
            <span
                class="med-font-mono med-text-xs med-tracking-widest med-uppercase med-mb-4 med-block medicion-modern-chapter"
                >{texts["modern.006"]}</span
            >
            <h2 class="med-text-4xl med-font-bold med-mb-8 medicion-modern-heading">
                {texts["modern.007"]}
            </h2>
            <p class="med-text-lg medicion-modern-body med-mb-8">
                {texts["modern.008"]}
                <br />
                {texts["modern.009"]}
            </p>
            <div class="medicion-modern-def">
                <p class="med-text-sm medicion-modern-def-title med-mb-2 med-font-bold">
                    {texts["modern.010"]}
                </p>
                <code class="med-text-xs medicion-modern-def-code med-block med-mb-2">
                    {texts["modern.011"]}
                </code>
                <p class="med-text-xs medicion-modern-def-note">
                    {texts["modern.012"]}
                    <strong>{texts["modern.013"]}</strong>{texts["modern.014"]}
                </p>
            </div>
        </div>

        <div class="medicion-modern-bottom">
            <div class="med-grid-cols-1 med-grid-cols-2\@md med-gap-16 med-items-center">
                <div class="med-space-y-8">
                    <h2
                        class="med-text-5xl med-font-bold med-tracking-tighter glitch-text"
                        data-text="YO, EL DATO"
                    >
                        {texts["modern.015"]}
                    </h2>
                    <p class="med-text-xl medicion-modern-body-accent">
                        {texts["modern.016"]}
                    </p>
                    <p class="med-text-lg medicion-modern-body-muted">
                        {texts["modern.017"]}
                    </p>
                    <p class="med-text-lg medicion-modern-emphasis med-font-bold">
                        {texts["modern.018"]}
                    </p>
                </div>

                <div class="med-grid-cols-2 med-gap-4 med-text-xs medicion-modern-stats">
                    <div class="medicion-modern-stat-card group">
                        <div class="medicion-modern-stat-label">{texts["modern.019"]}</div>
                        <div class="med-text-3xl med-font-bold medicion-modern-stat-value">
                            {texts["modern.020"]}
                        </div>
                        <div
                            class="med-w-full medicion-modern-bar-bg med-mt-4 med-rounded-full med-overflow-hidden"
                        >
                            <div class="medicion-modern-bar-fill medicion-modern-bar--70"></div>
                        </div>
                    </div>
                    <div class="medicion-modern-stat-card group">
                        <div class="medicion-modern-stat-label">{texts["modern.021"]}</div>
                        <div class="med-text-3xl med-font-bold medicion-modern-stat-value">
                            {texts["modern.022"]}
                        </div>
                        <div
                            class="med-w-full medicion-modern-bar-bg med-mt-4 med-rounded-full med-overflow-hidden"
                        >
                            <div class="medicion-modern-bar-fill medicion-modern-bar--85"></div>
                        </div>
                    </div>
                    <div class="medicion-modern-stat-card group">
                        <div class="medicion-modern-stat-label">
                            {texts["modern.023"]}
                        </div>
                        <div class="med-text-3xl med-font-bold medicion-modern-stat-value">
                            {texts["modern.024"]}
                        </div>
                        <div class="medicion-meta-label medicion-modern-negative med-mt-2">
                            {texts["modern.025"]}
                        </div>
                    </div>
                    <div class="medicion-modern-stat-card group">
                        <div class="medicion-modern-stat-label">
                            {texts["modern.026"]}
                        </div>
                        <div class="med-text-3xl med-font-bold medicion-modern-stat-value">
                            {texts["modern.027"]}
                        </div>
                        <div class="medicion-meta-label medicion-modern-positive med-mt-2">
                            {texts["modern.028"]}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .medicion-modern-section {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        padding-top: 8rem;
        padding-bottom: 8rem;
        background-color: #000000;
        color: #22c55e;
        font-family: monospace;
        overflow: hidden;
    }

    .medicion-modern-data-bg {
        opacity: 0.2;
        overflow: hidden;
        pointer-events: none;
    }

    .medicion-modern-intro {
        max-width: 56rem;
        margin-left: auto;
        margin-right: auto;
    }

    .medicion-modern-chapter {
        color: #15803d;
    }

    .medicion-modern-heading {
        color: #4ade80;
    }

    .medicion-modern-body {
        color: rgba(22, 163, 74, 0.8);
        line-height: 1.625;
    }

    .medicion-modern-def {
        background-color: rgba(22, 163, 74, 0.1);
        border: 1px solid rgba(22, 163, 74, 0.5);
        padding: 1.5rem;
        border-radius: 0.5rem;
        display: inline-block;
        text-align: left;
    }

    .medicion-modern-def-title {
        color: #16a34a;
    }

    .medicion-modern-def-code {
        color: #4ade80;
    }

    .medicion-modern-def-note {
        color: #166534;
    }

    .medicion-modern-bottom {
        max-width: 64rem;
        margin-left: auto;
        margin-right: auto;
    }

    .medicion-modern-body-accent {
        color: rgba(22, 163, 74, 0.9);
        line-height: 1.625;
    }

    .medicion-modern-body-muted {
        color: rgba(22, 163, 74, 0.7);
    }

    .medicion-modern-emphasis {
        color: #4ade80;
    }

    .medicion-modern-stats {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
        opacity: 0.9;
    }

    .medicion-modern-stat-card {
        border: 1px solid rgba(22, 163, 74, 0.5);
        padding: 1.5rem;
        border-radius: 0.25rem;
        background-color: #000000;
        transition: background-color 0.3s;
    }
    .medicion-modern-stat-card:hover {
        background-color: rgba(22, 163, 74, 0.1);
    }

    .medicion-modern-stat-label {
        color: #15803d;
        margin-bottom: 0.5rem;
        font-size: 0.875rem;
    }
    .group:hover .medicion-modern-stat-label {
        color: #22c55e;
    }

    .medicion-modern-stat-value {
        color: #ffffff;
    }
    .group:hover .medicion-modern-stat-value {
        color: #4ade80;
    }

    .medicion-modern-bar-bg {
        background-color: rgba(22, 163, 74, 0.3);
        height: 4px;
        border-radius: 9999px;
        overflow: hidden;
    }

    .medicion-modern-bar-fill {
        height: 100%;
        background-color: #22c55e;
    }

    .medicion-modern-bar--70 {
        width: 70%;
    }

    .medicion-modern-bar--85 {
        width: 85%;
    }

    .medicion-modern-negative {
        color: #ef4444;
    }

    .medicion-modern-positive {
        color: #22c55e;
    }

    .medicion-meta-label {
        font-size: 10px;
    }

    .data-stream {
        position: absolute;
        top: -100%;
        font-size: 20px;
        writing-mode: vertical-rl;
        text-orientation: upright;
        animation: fall 5s linear infinite;
        white-space: nowrap;
        color: #0f0;
        text-shadow: 0 0 5px #0f0;
    }

    @keyframes fall {
        to {
            transform: translateY(200vh);
        }
    }

    .glitch-text {
        position: relative;
    }

    .glitch-text::before,
    .glitch-text::after {
        content: attr(data-text);
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }

    .glitch-text::before {
        left: 2px;
        text-shadow: -1px 0 red;
        clip: rect(24px, 550px, 90px, 0);
        animation: glitch-anim-2 3s infinite linear alternate-reverse;
    }

    .glitch-text::after {
        left: -2px;
        text-shadow: -1px 0 blue;
        clip: rect(85px, 550px, 140px, 0);
        animation: glitch-anim 2.5s infinite linear alternate-reverse;
    }

    @keyframes glitch-anim {
        0% {
            clip: rect(12px, 9999px, 5px, 0);
        }
        20% {
            clip: rect(109px, 9999px, 86px, 0);
        }
        40% {
            clip: rect(35px, 9999px, 15px, 0);
        }
        60% {
            clip: rect(68px, 9999px, 10px, 0);
        }
        80% {
            clip: rect(12px, 9999px, 95px, 0);
        }
        100% {
            clip: rect(45px, 9999px, 66px, 0);
        }
    }

    @keyframes glitch-anim-2 {
        0% {
            clip: rect(65px, 9999px, 100px, 0);
        }
        20% {
            clip: rect(12px, 9999px, 5px, 0);
        }
        40% {
            clip: rect(89px, 9999px, 45px, 0);
        }
        60% {
            clip: rect(2px, 9999px, 15px, 0);
        }
        80% {
            clip: rect(45px, 9999px, 66px, 0);
        }
        100% {
            clip: rect(12px, 9999px, 85px, 0);
        }
    }
</style>
