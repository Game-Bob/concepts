---
import type { MeasurementTexts } from "../../../concepts/measurement/locales";

interface Props {
    texts: MeasurementTexts;
}

const { texts } = Astro.props;
---

<section class="med-section med-section-local">
    <div class="med-absolute med-inset-0 med-pointer-events-none medicion-bit-rain">
        {
            Array.from({ length: 20 }).map((_, i) => (
                <div
                    class="med-absolute med-text-xs animate-matrix-rain"
                    style={`left: ${i * 5}%; animation-duration: ${Math.random() * 2 + 2}s; animation-delay: ${Math.random() * 2}s;`}
                >
                    101101001
                </div>
            ))
        }
    </div>

    <div class="med-container">
        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <span class="medicion-bit-tag">{texts["bit.001"]}</span>
                <h2 class="med-text-4xl med-italic medicion-bit-title med-font-serif">
                    {texts["bit.002"]}
                </h2>

                <p class="med-text-lg medicion-bit-body">
                    {texts["bit.003"]}
                </p>

                <div class="med-card med-card-local">
                    <h3 class="med-card-title med-card-title-local">{texts["bit.004"]}</h3>
                    <p class="med-text-sm medicion-bit-card-text">
                        {texts["bit.005"]}
                    </p>
                    <p class="med-mt-4 med-text-sm medicion-bit-accent">
                        {texts["bit.006"]}
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-wrapper">
                    <svg viewBox="0 0 300 300" class="med-w-full med-h-full med-overflow-visible">
                        <g transform="translate(150, 150)">
                            <circle
                                cx="0"
                                cy="0"
                                r="50"
                                fill="#14532d"
                                stroke="#22c55e"
                                stroke-width="2"
                                class="animate-coin-flip"></circle>

                            <text
                                x="0"
                                y="15"
                                text-anchor="middle"
                                fill="#22c55e"
                                font-size="40"
                                font-weight="bold"
                                class="animate-text-1">{texts["bit.007"]}</text
                            >

                            <text
                                x="0"
                                y="15"
                                text-anchor="middle"
                                fill="#22c55e"
                                font-size="40"
                                font-weight="bold"
                                class="animate-text-0"
                                opacity="0">{texts["bit.008"]}</text
                            >
                        </g>

                        <g opacity="0.3" stroke="#22c55e" stroke-width="1">
                            <line x1="150" y1="210" x2="100" y2="260"></line>
                            <line x1="150" y1="210" x2="200" y2="260"></line>
                            <circle cx="100" cy="260" r="5" fill="#22c55e"></circle>
                            <circle cx="200" cy="260" r="5" fill="none"></circle>
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-card-title-local {
        color: #86efac;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #14532d 50%, transparent);
        border-color: #22c55e;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .medicion-bit-rain {
        opacity: 0.2;
        overflow: hidden;
    }

    .medicion-bit-tag {
        color: #4ade80;
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        border-bottom: 1px solid #15803d;
        padding-bottom: 0.5rem;
    }

    .medicion-bit-title {
        color: #ffffff;
    }

    .medicion-bit-body {
        color: rgba(187, 247, 208, 0.9);
        line-height: 1.625;
        font-family: sans-serif;
    }

    .medicion-bit-card-text {
        color: #dcfce7;
        line-height: 1.625;
        font-family: sans-serif;
    }

    .medicion-bit-accent {
        color: #4ade80;
        font-size: 0.875rem;
    }

    @keyframes matrixRain {
        from {
            transform: translateY(-100%);
        }
        to {
            transform: translateY(100vh);
        }
    }
    .animate-matrix-rain {
        writing-mode: vertical-rl;
        animation-timing-function: linear;
        animation-iteration-count: infinite;
    }

    @keyframes coinFlip {
        0% {
            transform: scaleY(1);
        }
        50% {
            transform: scaleY(0);
        }
        100% {
            transform: scaleY(1);
        }
    }
    .animate-coin-flip {
        animation: coinFlip 2s ease-in-out infinite;
    }

    @keyframes showOne {
        0%,
        49% {
            opacity: 1;
        }
        50%,
        100% {
            opacity: 0;
        }
    }
    .animate-text-1 {
        animation: showOne 2s step-end infinite;
    }

    @keyframes showZero {
        0%,
        49% {
            opacity: 0;
        }
        50%,
        100% {
            opacity: 1;
        }
    }
    .animate-text-0 {
        animation: showZero 2s step-end infinite;
    }
</style>
