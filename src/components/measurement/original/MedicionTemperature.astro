---
import type { MeasurementTexts } from "../../../concepts/measurement/locales";

interface Props {
    texts: MeasurementTexts;
}

const { texts } = Astro.props;
---

<section class="med-section med-section-local">
    <div class="med-container">
        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <span class="med-tag med-tag-local">{texts["temperature.001"]}</span>
                <h2 class="med-title med-title-local">
                    {texts["temperature.002"]}
                </h2>

                <p class="med-description med-description-local">
                    {texts["temperature.003"]}
                </p>

                <p class="med-description med-description-local">
                    {texts["temperature.004"]}
                </p>

                <div
                    class="med-p-6 med-rounded-sm med-border-l-2 med-mt-4"
                    style="background-color: #450a0a; border-color: rgba(239, 68, 68, 0.5);"
                >
                    <h3 class="med-font-bold med-mb-2" style="color: rgba(254, 202, 202, 0.8);">
                        {texts["temperature.005"]}
                    </h3>
                    <p class="med-card-text med-card-text-local">
                        {texts["temperature.006"]}
                    </p>
                    <p class="med-mt-2 med-text-sm med-italic" style="color: #a8a29e;">
                        {texts["temperature.007"]}
                    </p>
                </div>
            </div>

            <div class="med-visual-column">
                <div class="med-visual-sizer">
                    <div
                        class="med-absolute med-flex med-flex-col med-justify-between med-font-mono"
                        style="left: 1rem; top: 2rem; bottom: 2rem; width: 1rem; font-size: 10px; color: #78716c;"
                    >
                        <span>{texts["temperature.008"]}</span>
                        <span>{texts["temperature.009"]}</span>
                        <span>{texts["temperature.010"]}</span>
                        <span>{texts["temperature.011"]}</span>
                    </div>

                    <div
                        class="med-h-full med-rounded-full med-relative med-overflow-hidden med-border med-z-10"
                        style="width: 1rem; background-color: #292524; border-color: #57534e;"
                    >
                        <div
                            class="med-absolute med-bottom-0 med-left-0 med-right-0 med-transition-all med-duration-1000 animate-temp-rise"
                            style="background: linear-gradient(to top, #7f1d1d, #dc2626, #f97316); height: 40%;"
                        >
                        </div>
                    </div>

                    <div class="med-temp-bulb"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #2a0a0a;
        color: #e7e5e4;
    }

    .med-tag-local {
        color: #a8a29e;
        border-color: #a8a29e;
    }

    .med-title-local {
        color: #f5f5f4;
    }

    .med-description-local {
        color: #d6d3d1;
        opacity: 0.9;
    }

    .med-description-local {
        color: #d6d3d1;
        opacity: 0.9;
    }

    .med-card-text-local {
        color: #d6d3d1;
    }

    @keyframes tempRise {
        0% {
            height: 20%;
            filter: hue-rotate(0deg);
        }
        50% {
            height: 70%;
            filter: hue-rotate(20deg);
        }
        100% {
            height: 20%;
            filter: hue-rotate(0deg);
        }
    }
    .animate-temp-rise {
        animation: tempRise 8s ease-in-out infinite;
    }
    .med-temp-bulb {
        position: absolute;
        bottom: 0.5rem;
        width: 3rem;
        height: 3rem;
        background-color: #991b1b;
        border-radius: 9999px;
        border: 1px solid #57534e;
        z-index: 20;
        box-shadow: 0 0 20px rgba(220, 38, 38, 0.4);
    }

    .med-visual-sizer {
        position: relative;
        width: 8rem;
        height: 24rem;
        background-color: #1a0505;
        border: 1px solid #450a0a;
        border-radius: 9999px;
        padding: 1rem;
        display: flex;
        justify-content: center;
        box-sizing: border-box;
    }
</style>
