---
import type { MeasurementTexts } from "../../../concepts/measurement/locales";

interface Props {
    texts: MeasurementTexts;
}

const { texts } = Astro.props;
---

<section class="med-section med-section-local">
    <div class="med-container med-container--xwide">
        <div class="med-grid-cols-1 med-grid-cols-2\@md med-gap-16 med-items-center">
            <div class="med-space-y-8">
                <h2
                    class="med-text-5xl med-font-bold med-tracking-tighter glitch-text"
                    data-text="YO, EL DATO"
                >
                    {texts["quantifiedSelf.001"]}
                </h2>
                <p class="med-text-xl medicion-qs-body">
                    {texts["quantifiedSelf.002"]}
                </p>
                <p class="med-text-lg medicion-qs-body-muted">
                    {texts["quantifiedSelf.003"]}
                </p>
                <p
                    class="med-text-lg medicion-qs-emphasis med-font-bold med-border-l-4 medicion-qs-border med-pl-4"
                >
                    {texts["quantifiedSelf.004"]}
                </p>
            </div>

            <div class="med-grid-cols-2 med-gap-4">
                <div class="medicion-qs-card group">
                    <div
                        class="med-text-xs medicion-qs-card-label med-mb-2 med-uppercase med-tracking-widest"
                    >
                        {texts["quantifiedSelf.005"]}
                    </div>
                    <div class="med-text-3xl med-font-bold medicion-qs-card-value">
                        {texts["quantifiedSelf.006"]}
                    </div>
                    <div
                        class="med-w-full medicion-qs-bar-bg med-mt-4 med-rounded-full med-overflow-hidden"
                    >
                        <div class="medicion-qs-bar-fill medicion-qs-bar--70"></div>
                    </div>
                </div>

                <div class="medicion-qs-card group">
                    <div
                        class="med-text-xs medicion-qs-card-label med-mb-2 med-uppercase med-tracking-widest"
                    >
                        {texts["quantifiedSelf.007"]}
                    </div>
                    <div class="med-text-3xl med-font-bold medicion-qs-card-value">
                        {texts["quantifiedSelf.008"]}
                    </div>
                    <div
                        class="med-w-full medicion-qs-bar-bg med-mt-4 med-rounded-full med-overflow-hidden"
                    >
                        <div class="medicion-qs-bar-fill medicion-qs-bar--85"></div>
                    </div>
                </div>

                <div class="medicion-qs-card group">
                    <div
                        class="med-text-xs medicion-qs-card-label med-mb-2 med-uppercase med-tracking-widest"
                    >
                        {texts["quantifiedSelf.009"]}
                    </div>
                    <div class="med-text-3xl med-font-bold medicion-qs-card-value">
                        {texts["quantifiedSelf.010"]}
                    </div>
                    <div class="medicion-meta-label medicion-qs-negative med-mt-2">
                        {texts["quantifiedSelf.011"]}
                    </div>
                </div>

                <div class="medicion-qs-card group">
                    <div
                        class="med-text-xs medicion-qs-card-label med-mb-2 med-uppercase med-tracking-widest"
                    >
                        {texts["quantifiedSelf.012"]}
                    </div>
                    <div class="med-text-3xl med-font-bold medicion-qs-card-value">
                        {texts["quantifiedSelf.013"]}
                    </div>
                    <div class="medicion-meta-label medicion-qs-positive med-mt-2">
                        {texts["quantifiedSelf.014"]}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #000000;
        color: #ffffff;
    }

    .medicion-qs-body {
        color: #a3a3a3;
        line-height: 1.625;
    }

    .medicion-qs-body-muted {
        color: #737373;
    }

    .medicion-qs-emphasis {
        color: #ffffff;
    }

    .medicion-qs-border {
        border-color: #ffffff;
    }

    .medicion-qs-card {
        background-color: #171717;
        padding: 1.5rem;
        border-radius: 0.25rem;
        border: 1px solid #262626;
        transition: all 0.3s;
    }
    .medicion-qs-card:hover {
        border-color: #525252;
    }

    .medicion-qs-card-label {
        color: #737373;
    }

    .medicion-qs-card-value {
        color: #ffffff;
        transition: color 0.3s;
    }
    .group:hover .medicion-qs-card-value {
        color: #22d3ee;
    }

    .medicion-qs-bar-bg {
        background-color: #262626;
        height: 4px;
        border-radius: 9999px;
        overflow: hidden;
    }

    .medicion-qs-bar-fill {
        height: 100%;
        background-color: #22d3ee;
    }

    .medicion-qs-bar--70 {
        width: 70%;
    }

    .medicion-qs-bar--85 {
        width: 85%;
    }

    .medicion-meta-label {
        font-size: 10px;
    }
    .medicion-qs-negative {
        color: #ef4444;
    }

    .medicion-qs-positive {
        color: #22c55e;
    }

    .glitch-text {
        position: relative;
    }

    .glitch-text::before,
    .glitch-text::after {
        content: attr(data-text);
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }

    .glitch-text::before {
        left: 2px;
        text-shadow: -1px 0 red;
        clip: rect(24px, 550px, 90px, 0);
        animation: glitch-anim-2 3s infinite linear alternate-reverse;
    }

    .glitch-text::after {
        left: -2px;
        text-shadow: -1px 0 blue;
        clip: rect(85px, 550px, 140px, 0);
        animation: glitch-anim 2.5s infinite linear alternate-reverse;
    }

    @keyframes glitch-anim {
        0% {
            clip: rect(12px, 9999px, 5px, 0);
        }
        20% {
            clip: rect(109px, 9999px, 86px, 0);
        }
        40% {
            clip: rect(35px, 9999px, 15px, 0);
        }
        60% {
            clip: rect(68px, 9999px, 10px, 0);
        }
        80% {
            clip: rect(12px, 9999px, 95px, 0);
        }
        100% {
            clip: rect(45px, 9999px, 66px, 0);
        }
    }

    @keyframes glitch-anim-2 {
        0% {
            clip: rect(65px, 9999px, 100px, 0);
        }
        20% {
            clip: rect(12px, 9999px, 5px, 0);
        }
        40% {
            clip: rect(89px, 9999px, 45px, 0);
        }
        60% {
            clip: rect(2px, 9999px, 15px, 0);
        }
        80% {
            clip: rect(45px, 9999px, 66px, 0);
        }
        100% {
            clip: rect(12px, 9999px, 85px, 0);
        }
    }
</style>
