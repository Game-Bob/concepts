---
import type { MeasurementTexts } from "../../../concepts/measurement/locales";

interface Props {
    texts: MeasurementTexts;
}

const { texts } = Astro.props;
---

<section class="med-section med-section-local">
    <div class="med-container">
        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <h2 class="med-title med-title-local">
                    {texts["grain.001"]}
                </h2>

                <p class="med-description med-description-local">
                    {texts["grain.002"]}
                </p>
                <p class="med-description med-description-local">
                    {texts["grain.003"]}
                    <strong>{texts["grain.004"]}</strong>
                </p>

                <div class="med-space-y-4 med-mt-8">
                    <div class="med-card--left-border med-card-grain">
                        <p class="med-card-text med-card-text-local">
                            {texts["grain.005"]}
                            <strong>{texts["grain.006"]}</strong>{texts["grain.007"]}
                        </p>
                    </div>
                    <div class="med-card--left-border med-card-grain">
                        <p class="med-card-text med-card-text-local">
                            {texts["grain.008"]}
                        </p>
                    </div>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-grain-circle">
                    <div class="med-grain-grid">
                        {
                            Array.from({ length: 24 }).map(() => (
                                <div
                                    class="med-grain-dot"
                                    style={`transform: rotate(${Math.random() * 360}deg) scale(${0.5 + Math.random() * 0.5})`}
                                />
                            ))
                        }
                    </div>
                    <div class="med-grain-center">
                        <div class="med-grain-value">{texts["grain.009"]}</div>
                        <div class="med-grain-label">{texts["grain.010"]}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #18181b;
        color: #e4e4e7;
    }
    .med-title-local {
        color: #f4f4f5;
    }
    .med-description-local {
        color: #d4d4d8;
        opacity: 0.9;
    }
    .med-card-text-local {
        color: #e4e4e7;
    }
    .med-card-grain {
        background-color: #27272a;
        padding: 1.5rem;
        border-radius: 0.125rem;
        border-left: 2px solid #a1a1aa;
        backdrop-filter: blur(4px);
    }
    .med-visual-column-local {
        display: flex;
        justify-content: center;
        width: 100%;
    }
    @media (min-width: 768px) {
        .med-visual-column-local {
            width: 50%;
        }
        .med-grain-circle {
            width: 20rem;
            height: 20rem;
        }
    }
    .med-grain-circle {
        position: relative;
        width: 16rem;
        height: 16rem;
        background-color: #09090b;
        border-radius: 9999px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #27272a;
    }
    .med-grain-grid {
        position: absolute;
        inset: 0;
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 0.5rem;
        opacity: 0.5;
        padding: 2rem;
    }
    .med-grain-dot {
        width: 100%;
        height: 100%;
        background-color: #e4e4e7;
        border-radius: 9999px;
        opacity: 0.2;
    }
    .med-grain-center {
        z-index: 10;
        text-align: center;
        padding: 2rem;
        background-color: #18181b;
        border-radius: 9999px;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.25);
        border: 1px solid #27272a;
    }
    .med-grain-value {
        font-size: 2.25rem;
        font-weight: bold;
        color: #f4f4f5;
        margin-bottom: 0.25rem;
    }
    .med-grain-label {
        font-size: 0.625rem;
        font-family: monospace;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: #a1a1aa;
    }
</style>
