---
import type { MeasurementTexts } from "../../../concepts/measurement/locales";

interface Props {
    texts: MeasurementTexts;
}

const { texts } = Astro.props;
---

<section class="med-section med-section-local">
    <div class="med-absolute med-inset-0 med-pointer-events-none med-opacity-10">
        <svg class="med-w-full med-h-full">
            <defs>
                <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
                    <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#a1a1aa" stroke-width="1"
                    ></path>
                </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#grid)"></rect>
        </svg>
    </div>

    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <span class="med-tag med-tag-local">{texts["galton.001"]}</span>
                <h2 class="med-title med-title-local">
                    {texts["galton.002"]}
                </h2>

                <p class="med-description med-description-local">
                    {texts["galton.003"]}
                </p>

                <div class="med-card med-card-local">
                    <h3 class="med-card-title med-card-title-local">{texts["galton.004"]}</h3>
                    <p class="med-card-text med-card-text-local">
                        {texts["galton.005"]}
                    </p>
                    <p class="med-card-note med-card-note-local">
                        {texts["galton.006"]}
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-wrapper">
                    <svg viewBox="0 0 400 400" class="med-w-full med-h-full med-overflow-visible">
                        <path
                            d="M 100 50 L 100 300 L 300 300 L 300 50"
                            fill="none"
                            stroke="#52525b"
                            stroke-width="2"></path>

                        <g fill="#71717a">
                            {
                                Array.from({ length: 8 }).map((_, row) =>
                                    Array.from({ length: row + 1 }).map((_, col) => (
                                        <circle
                                            cx={200 + (col - row / 2) * 20}
                                            cy={80 + row * 25}
                                            r={2}
                                        />
                                    ))
                                )
                            }
                        </g>

                        <g transform="translate(100, 300)">
                            {
                                Array.from({ length: 9 }).map((_, i) => (
                                    <rect
                                        x={i * 22.2 + 2}
                                        y="0"
                                        width="18"
                                        height="50"
                                        fill="none"
                                        stroke="#3f3f46"
                                        stroke-width="1"
                                    />
                                ))
                            }
                        </g>

                        <g>
                            {
                                Array.from({ length: 20 }).map((_, i) => {
                                    const delay = i * 0.5;

                                    const endBin = Math.floor(Math.random() * 9);
                                    const endX = 100 + endBin * 22.2 + 11;

                                    return (
                                        <circle
                                            r="4"
                                            fill="#e4e4e7"
                                            class="animate-galton-ball"
                                            style={`animation-delay: ${delay}s; --end-x: ${endX}px;`}
                                        />
                                    );
                                })
                            }
                        </g>

                        <path
                            d="M 100 300 Q 150 300 170 250 Q 200 150 230 250 Q 250 300 300 300"
                            fill="none"
                            stroke="#22d3ee"
                            stroke-width="2"
                            opacity="0.3"
                            stroke-dasharray="4 4"></path>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #18181b;
        color: #e4e4e7;
    }

    .med-tag-local {
        color: #a1a1aa;
        border-color: #52525b;
    }

    .med-title-local {
        color: #f4f4f5;
    }

    .med-description-local {
        color: #d4d4d8;
        opacity: 0.9;
    }

    .med-card-title-local {
        color: #e4e4e7;
    }

    .med-card-text-local {
        color: #a1a1aa;
    }

    .med-card-note-local {
        color: #d4d4d8;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #27272a 50%, transparent);
        border-color: #52525b;
    }

    @keyframes galtonBall {
        0% {
            cx: 200px;
            cy: 40px;
            opacity: 0;
        }
        10% {
            cx: 200px;
            cy: 40px;
            opacity: 1;
        }

        20% {
            cx: 205px;
            cy: 80px;
        }
        30% {
            cx: 195px;
            cy: 105px;
        }
        40% {
            cx: 210px;
            cy: 130px;
        }
        50% {
            cx: 200px;
            cy: 155px;
        }
        60% {
            cx: 215px;
            cy: 180px;
        }
        70% {
            cx: var(--end-x);
            cy: 280px;
        }
        90% {
            cx: var(--end-x);
            cy: 340px;
            opacity: 1;
        }
        100% {
            cx: var(--end-x);
            cy: 340px;
            opacity: 0;
        }
    }
    .animate-galton-ball {
        animation: galtonBall 4s linear infinite;
    }
</style>
