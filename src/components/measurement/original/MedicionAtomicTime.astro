---
import type { MeasurementTexts } from "../../../concepts/measurement/locales";

interface Props {
    texts: MeasurementTexts;
}

const { texts } = Astro.props;
---

<section class="med-section med-section-local">
    <div
        class="med-absolute med-inset-0 medicion-atom-grid"
        style="background-image: radial-gradient(#6366f1 1px, transparent 1px); background-size: 30px 30px;"
    >
    </div>

    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <span class="med-tag med-tag-local">{texts["atomicTime.001"]}</span>
                <h2 class="med-text-4xl med-font-bold med-tracking-tight medicion-atom-title">
                    {texts["atomicTime.002"]}
                </h2>

                <p class="med-text-lg medicion-atom-body">
                    {texts["atomicTime.003"]}
                </p>

                <div class="med-card med-card-local">
                    <h3 class="med-card-title med-card-title-local">{texts["atomicTime.004"]}</h3>
                    <p class="med-card-text med-card-text-local">
                        {texts["atomicTime.005"]}
                        <strong>{texts["atomicTime.006"]}</strong>{texts["atomicTime.007"]}
                    </p>
                    <div class="med-mt-4 med-flex med-items-center med-gap-4">
                        <div class="med-dot med-dot--green med-dot--pulse"></div>
                        <span class="med-font-mono med-text-xs medicion-atom-sync"
                            >{texts["atomicTime.008"]}</span
                        >
                    </div>
                </div>

                <p class="med-text-sm med-italic medicion-atom-note">
                    {texts["atomicTime.009"]}
                </p>
            </div>

            <div class="med-visual-column">
                <div class="med-visual-sizer">
                    <div
                        class="med-absolute med-w-full med-h-full med-rounded-full medicion-atom-orbit animate-spin-atom-1"
                    >
                    </div>
                    <div
                        class="med-absolute med-w-full med-h-full med-rounded-full medicion-atom-orbit animate-spin-atom-2"
                    >
                    </div>
                    <div
                        class="med-absolute med-w-full med-h-full med-rounded-full medicion-atom-orbit animate-spin-atom-3"
                    >
                    </div>

                    <div class="med-relative medicion-atom-core animate-pulse-fast"></div>

                    <div
                        class="med-absolute med-top-0 med-left-1/2 medicion-atom-electron animate-orbit-1"
                    >
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #111827;
        color: #e5e7eb;
    }

    .med-tag-local {
        color: #818cf8;
        border-color: #4338ca;
    }

    .med-card-title-local {
        color: #818cf8;
    }

    .med-card-text-local {
        color: #d1d5db;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #1f2937 50%, transparent);
        border-color: #3730a3;
    }

    .medicion-atom-grid {
        opacity: 0.1;
    }

    .medicion-atom-title {
        color: #ffffff;
    }

    .medicion-atom-body {
        color: #9ca3af;
        line-height: 1.625;
    }

    .medicion-atom-sync {
        color: #4ade80;
    }

    .medicion-atom-note {
        color: #6b7280;
    }

    .medicion-atom-orbit {
        border: 1px solid rgba(99, 102, 241, 0.3);
    }

    .medicion-atom-core {
        z-index: 10;
        width: 2rem;
        height: 2rem;
        background-color: #ffffff;
        border-radius: 9999px;
        box-shadow: 0 0 30px #6366f1;
    }

    .medicion-atom-electron {
        width: 0.75rem;
        height: 0.75rem;
        background-color: #818cf8;
        border-radius: 9999px;
        box-shadow: 0 0 10px #818cf8;
    }

    @keyframes spinAtom1 {
        0% {
            transform: rotateX(70deg) rotateY(10deg) rotateZ(0deg);
        }
        100% {
            transform: rotateX(70deg) rotateY(10deg) rotateZ(360deg);
        }
    }
    .animate-spin-atom-1 {
        animation: spinAtom1 3s linear infinite;
    }

    @keyframes spinAtom2 {
        0% {
            transform: rotateX(120deg) rotateY(60deg) rotateZ(0deg);
        }
        100% {
            transform: rotateX(120deg) rotateY(60deg) rotateZ(360deg);
        }
    }
    .animate-spin-atom-2 {
        animation: spinAtom2 4s linear infinite;
    }

    @keyframes spinAtom3 {
        0% {
            transform: rotateX(10deg) rotateY(150deg) rotateZ(0deg);
        }
        100% {
            transform: rotateX(10deg) rotateY(150deg) rotateZ(360deg);
        }
    }
    .animate-spin-atom-3 {
        animation: spinAtom3 5s linear infinite;
    }

    @keyframes pulseFast {
        0%,
        100% {
            transform: scale(1);
            opacity: 1;
        }
        50% {
            transform: scale(1.2);
            opacity: 0.8;
        }
    }
    .animate-pulse-fast {
        animation: pulseFast 0.5s ease-in-out infinite;
    }
    .med-visual-sizer {
        position: relative;
        width: 20rem;
        height: 20rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>
