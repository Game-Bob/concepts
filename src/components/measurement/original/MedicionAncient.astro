---
import type { MeasurementTexts } from "../../../concepts/measurement/locales";

interface Props {
    texts: MeasurementTexts;
}

const { texts } = Astro.props;
---

<section class="med-section med-section-local">
    <div class="med-absolute med-inset-0 medicion-ancient-bg-overlay med-pointer-events-none"></div>

    <div class="med-container">
        <div class="med-flex med-flex-col medicion-ancient-row med-items-center med-mb-32">
            <div class="med-info-column">
                <span class="med-tag med-tag-local">{texts["ancient.001"]}</span>
                <h2 class="med-text-4xl med-font-serif med-italic medicion-ancient-title">
                    {texts["ancient.002"]}
                </h2>

                <p class="med-description med-description-local">
                    {texts["ancient.003"]}
                </p>
                <p class="med-description med-description-local">
                    {texts["ancient.004"]}
                </p>

                <div class="med-grid-cols-1 medicion-ancient-cards med-gap-8 med-mt-8">
                    <div class="medicion-ancient-card">
                        <h3 class="med-text-xl med-font-bold medicion-ancient-card-title med-mb-2">
                            {texts["ancient.005"]}
                        </h3>
                        <p class="med-text-sm medicion-ancient-card-sub">{texts["ancient.006"]}</p>
                        <p class="med-mt-2 med-text-sm medicion-ancient-card-text">
                            {texts["ancient.007"]}
                            <br /><span class="med-italic medicion-ancient-card-note"
                                >{texts["ancient.008"]}</span
                            >
                        </p>
                    </div>
                    <div class="medicion-ancient-card">
                        <h3 class="med-text-xl med-font-bold medicion-ancient-card-title med-mb-2">
                            {texts["ancient.009"]}
                        </h3>
                        <p class="med-text-sm medicion-ancient-card-sub">{texts["ancient.010"]}</p>
                        <p class="med-mt-2 med-text-sm medicion-ancient-card-text">
                            {texts["ancient.011"]}
                            <br /><span class="med-italic medicion-ancient-card-note"
                                >{texts["ancient.012"]}</span
                            >
                        </p>
                    </div>
                </div>
            </div>

            <div
                class="med-w-full medicion-ancient-visual-col med-relative medicion-ancient-visual-box med-flex med-items-center med-justify-center"
            >
                <div
                    class="med-absolute med-inset-0 med-flex med-items-center med-justify-center medicion-ancient-svg-overlay"
                >
                    <svg viewBox="0 0 200 200" class="med-w-full med-h-full animate-spin-slow">
                        <circle
                            cx="100"
                            cy="100"
                            r="90"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="0.5"
                            stroke-dasharray="2,2"></circle>
                        <path
                            d="M100 10 L100 190 M10 100 L190 100"
                            stroke="currentColor"
                            stroke-width="0.2"></path>
                    </svg>
                </div>

                <div class="med-relative medicion-ancient-quote med-text-center med-space-y-8">
                    <div class="med-space-y-2">
                        <div
                            class="med-text-xs med-font-mono medicion-ancient-quote-label med-uppercase med-tracking-widest"
                        >
                            {texts["ancient.013"]}
                        </div>
                        <p class="med-text-xl med-font-serif med-italic">{texts["ancient.014"]}</p>
                    </div>

                    <p class="med-text-sm medicion-ancient-quote-text">
                        {texts["ancient.015"]}
                    </p>

                    <div class="medicion-ancient-warning">
                        <span class="med-block med-font-bold med-mb-1">{texts["ancient.016"]}</span>
                        {texts["ancient.017"]}
                        <span class="med-font-bold medicion-ancient-em">{texts["ancient.018"]}</span
                        >
                        {texts["ancient.019"]}
                    </div>
                </div>
            </div>
        </div>

        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <span class="med-tag med-tag-local">{texts["ancient.020"]}</span>
                <h2 class="med-title med-title-local">
                    {texts["ancient.021"]}
                </h2>

                <p class="med-description med-description-local">
                    {texts["ancient.022"]}
                </p>
                <p class="med-description med-description-local">
                    {texts["ancient.023"]}
                    <strong>{texts["ancient.024"]}</strong>
                </p>

                <ul class="med-space-y-4 med-mt-4 medicion-ancient-list">
                    <li class="med-flex med-items-start med-gap-4">
                        <span
                            >{texts["ancient.026"]}
                            <strong>{texts["ancient.027"]}</strong>{texts["ancient.028"]}</span
                        >
                    </li>
                    <li class="med-flex med-items-start med-gap-4">
                        <span>{texts["ancient.030"]}</span>
                    </li>
                </ul>
            </div>

            <div class="med-w-full medicion-ancient-visual-col med-flex med-justify-center">
                <div class="med-relative medicion-ancient-grain-sizer">
                    <div
                        class="med-absolute med-inset-0 med-grid-cols-6 med-gap-2 medicion-ancient-grains"
                    >
                        {
                            Array.from({ length: 36 }).map(() => (
                                <div
                                    class="medicion-ancient-grain"
                                    style={`transform: rotate(${Math.random() * 360}deg) scale(${0.8 + Math.random() * 0.4})`}
                                />
                            ))
                        }
                    </div>
                    <div
                        class="med-absolute med-inset-0 med-flex med-items-center med-justify-center"
                    >
                        <div class="med-text-center">
                            <div class="med-text-6xl med-font-bold medicion-ancient-weight">
                                {texts["ancient.031"]}
                            </div>
                            <div
                                class="med-text-sm med-font-mono med-uppercase med-tracking-widest medicion-ancient-weight-label"
                            >
                                {texts["ancient.032"]}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #1a1816;
        color: #d6d3d1;
    }

    .med-tag-local {
        color: #a8a29e;
        border-color: #a8a29e;
    }

    .med-title-local {
        color: #e7e5e4;
    }

    .med-description-local {
        color: #d6d3d1;
        opacity: 0.9;
    }

    .medicion-ancient-bg-overlay {
        opacity: 0.05;
        pointer-events: none;
    }

    .medicion-ancient-row {
        flex-direction: column;
        gap: 4rem;
    }
    @media (min-width: 768px) {
        .medicion-ancient-row {
            flex-direction: row;
        }
    }

    .medicion-ancient-title {
        color: #e7e5e4;
    }

    .medicion-ancient-cards {
        display: grid;
        grid-template-columns: repeat(1, 1fr);
        gap: 2rem;
        margin-top: 2rem;
    }
    @media (min-width: 640px) {
        .medicion-ancient-cards {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .medicion-ancient-card {
        border-left: 1px solid #57534e;
        padding-left: 1.5rem;
        padding-top: 0.5rem;
        padding-bottom: 0.5rem;
    }

    .medicion-ancient-card-title {
        color: #e7e5e4;
    }

    .medicion-ancient-card-sub {
        color: #a8a29e;
    }

    .medicion-ancient-card-text {
        line-height: 1.625;
        color: #d6d3d1;
    }

    .medicion-ancient-card-note {
        color: #78716c;
    }

    .medicion-ancient-visual-col {
        width: 100%;
    }
    @media (min-width: 768px) {
        .medicion-ancient-visual-col {
            width: 50%;
        }
    }

    .medicion-ancient-visual-box {
        height: 600px;
        border: 1px solid #44403c;
        padding: 2rem;
        border-radius: 0.125rem;
        background-color: #0c0a09;
    }

    .medicion-ancient-svg-overlay {
        opacity: 0.1;
    }

    .medicion-ancient-quote {
        z-index: 10;
        max-width: 20rem;
    }

    .medicion-ancient-quote-label {
        color: #78716c;
    }

    .medicion-ancient-quote-text {
        color: #a8a29e;
        line-height: 1.625;
    }

    .medicion-ancient-warning {
        padding: 1rem;
        border: 1px solid rgba(127, 29, 29, 0.3);
        background-color: rgba(127, 29, 29, 0.1);
        border-radius: 0.25rem;
        color: rgba(254, 202, 202, 0.8);
        font-size: 0.875rem;
    }

    .medicion-ancient-em {
        color: #ffffff;
    }

    .medicion-ancient-list {
        color: #a8a29e;
    }

    .medicion-ancient-icon {
        color: #e7e5e4;
    }

    .medicion-ancient-grain-sizer {
        position: relative;
        width: 16rem;
        height: 16rem;
    }
    @media (min-width: 768px) {
        .medicion-ancient-grain-sizer {
            width: 24rem;
            height: 24rem;
        }
    }

    .medicion-ancient-grains {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 0.5rem;
        opacity: 0.5;
    }

    .medicion-ancient-grain {
        width: 100%;
        height: 100%;
        background-color: #d6d3d1;
        border-radius: 9999px;
        opacity: 0.2;
    }

    .medicion-ancient-weight {
        color: #e7e5e4;
        margin-bottom: 0.5rem;
    }

    .medicion-ancient-weight-label {
        color: #a8a29e;
    }

    .animate-spin-slow {
        animation: spin 60s linear infinite;
    }
    @keyframes spin {
        from {
            transform: rotate(0deg);
        }
        to {
            transform: rotate(360deg);
        }
    }
</style>
