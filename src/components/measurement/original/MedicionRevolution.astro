---
import type { MeasurementTexts } from "../../../concepts/measurement/locales";

interface Props {
    texts: MeasurementTexts;
}

const { texts } = Astro.props;
---

<section class="med-section med-section-local">
    <div
        class="med-absolute med-inset-0"
        style="background-image: linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 50px 50px;"
    >
    </div>

    <div class="med-container med-text-center">
        <div class="med-mb-16">
            <span
                class="med-text-cyan-500 med-font-mono med-text-xs med-tracking-widest med-uppercase med-mb-4 med-block"
                >{texts["revolution.001"]}</span
            >
            <h2 class="med-text-5xl med-text-8xl@md med-font-bold med-tracking-tight med-mb-8">
                {texts["revolution.002"]}
            </h2>
            <div class="med-divider-line med-mx-auto med-mb-8"></div>
        </div>

        <div class="med-prose med-prose-lg med-mx-auto">
            <p class="med-text-xl med-text-neutral-300 med-leading-relaxed">
                {texts["revolution.003"]}
            </p>
            <p class="med-text-xl med-text-neutral-300 med-leading-relaxed">
                {texts["revolution.004"]}
            </p>
            <blockquote
                class="med-text-2xl med-font-serif med-italic med-text-white med-my-12 med-border-l-4 med-border-cyan-500 med-pl-6 med-py-2 med-bg-neutral-800-50 med-blockquote-local"
            >
                {texts["revolution.005"]}
            </blockquote>
            <p class="med-text-neutral-400">{texts["revolution.006"]}</p>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #171717;
        color: #ffffff;
    }

    .med-text-cyan-500 {
        color: #06b6d4;
    }
    .med-text-neutral-300 {
        color: #d4d4d4;
    }
    .med-text-neutral-400 {
        color: #a3a3a3;
    }
    .med-text-white {
        color: #ffffff;
    }
    .med-border-cyan-500 {
        border-color: #06b6d4;
    }
    .med-bg-neutral-800-50 {
        background-color: rgba(38, 38, 38, 0.5);
    }
    .med-divider-line {
        width: 6rem;
        height: 0.25rem;
        background-color: #06b6d4;
    }
    .med-blockquote-local {
        border-top-right-radius: 0.5rem;
        border-bottom-right-radius: 0.5rem;
    }
</style>
