<div class="inf-slider-container">
    <input
        type="range"
        min="1970"
        max="2025"
        value="2025"
        class="inf-slider-input"
        id="year-slider"
    />

    <div class="inf-slider-labels">
        <span>1970</span>
        <span>2025</span>
    </div>
</div>

<style>
    .inf-slider-container {
        position: relative;
        padding-left: 1rem;
        padding-right: 1rem;
        max-width: 36rem;
        margin: 2rem auto 3rem;
    }

    .inf-slider-input {
        width: 100%;
        height: 0.5rem;
        background: #fde68a;
        border-radius: 0.5rem;
        appearance: none;
        cursor: pointer;
        z-index: 10;
        position: relative;
        outline: none;
    }

    .theme-dark .inf-slider-input {
        background: #3f3f46;
    }

    .inf-slider-labels {
        display: flex;
        justify-content: space-between;
        font-size: 0.75rem;
        margin-top: 1rem;
        color: rgb(120 53 15 / 0.6);
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .theme-dark .inf-slider-labels {
        color: rgb(254 243 199 / 0.6);
    }

    input[type="range"]::-webkit-slider-thumb {
        appearance: none;
        height: 24px;
        width: 24px;
        border-radius: 50%;
        background: #78350f;
        cursor: pointer;
        margin-top: -8px;
        box-shadow: 0 0 0 4px rgb(251 191 36 / 0.5);
        transition: transform 0.1s;
    }

    .theme-dark input[type="range"]::-webkit-slider-thumb {
        background: #fde68a;
    }

    input[type="range"]::-webkit-slider-thumb:hover {
        transform: scale(1.1);
        box-shadow: 0 0 0 6px rgb(251 191 36 / 0.3);
    }

    input[type="range"]::-webkit-slider-runnable-track {
        width: 100%;
        height: 8px;
        cursor: pointer;
        background: #fde68a;
        border-radius: 4px;
    }

    .theme-dark input[type="range"]::-webkit-slider-runnable-track {
        background: #3f3f46;
    }

    input[type="range"]::-moz-range-thumb {
        height: 24px;
        width: 24px;
        border: none;
        border-radius: 50%;
        background: #78350f;
        cursor: pointer;
        box-shadow: 0 0 0 4px rgb(251 191 36 / 0.5);
    }

    .theme-dark input[type="range"]::-moz-range-thumb {
        background: #fde68a;
    }
</style>
