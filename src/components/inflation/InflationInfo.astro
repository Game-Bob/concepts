---
import type { InflationLocaleData } from "../../concepts/inflation/types";

interface Props {
    locale: InflationLocaleData;
}

const { locale } = Astro.props;
---

<section class="inf-info-section">
    <div class="inf-info-prose">
        <h2 class="inf-info-h2">
            {locale.infoTitle}
        </h2>

        <p class="inf-info-p" set:html={locale.infoP1} />

        <h3 class="inf-info-h3">{locale.infoSubtitle1}</h3>
        <p class="inf-info-p" set:html={locale.infoP2} />

        <h3 class="inf-info-h3">{locale.infoSubtitle2}</h3>
        <p class="inf-info-p" set:html={locale.infoP3} />

        <div class="inf-info-box">
            <h3 class="inf-info-box-h3">{locale.infoScienceTitle}</h3>
            <p class="inf-info-box-p" set:html={locale.infoScienceText} />
        </div>
    </div>
</section>

<style>
    .inf-info-section {
        max-width: 48rem;
        margin: 1.5rem auto;
        padding: 0 1.5rem;
        line-height: 1.625;
    }

    .theme-light .inf-info-section {
        color: rgb(120 53 15 / 0.8);
    }

    .theme-dark .inf-info-section {
        color: rgb(254 243 199 / 0.8);
    }

    .theme-light .inf-info-prose strong {
        color: #78350f;
    }

    .theme-dark .inf-info-prose strong {
        color: #fde68a;
    }

    .inf-info-h2 {
        font-size: 1.875rem;
        font-weight: 900;
        margin-bottom: 1.5rem;
        letter-spacing: -0.025em;
        line-height: 1.25;
    }

    .theme-light .inf-info-h2 {
        color: #78350f;
    }

    .theme-dark .inf-info-h2 {
        color: #fde68a;
    }

    .inf-info-p {
        margin-bottom: 1.5rem;
    }

    .inf-info-h3 {
        font-size: 1.25rem;
        font-weight: bold;
        margin-top: 2rem;
        margin-bottom: 1rem;
    }

    .theme-light .inf-info-h3 {
        color: #78350f;
    }

    .theme-dark .inf-info-h3 {
        color: #fde68a;
    }

    .inf-info-box {
        padding: 1.5rem;
        border-radius: 1rem;
        margin-top: 2rem;
        margin-bottom: 3rem;
    }

    .theme-light .inf-info-box {
        background-color: rgb(253 230 138 / 0.25);
        border: 1px solid #fde68a;
    }

    .theme-dark .inf-info-box {
        background-color: rgb(39 39 42 / 0.5);
        border: 1px solid #3f3f46;
    }

    .inf-info-box-h3 {
        font-size: 1.125rem;
        font-weight: bold;
        margin-bottom: 0.5rem;
    }

    .theme-light .inf-info-box-h3 {
        color: #78350f;
    }

    .theme-dark .inf-info-box-h3 {
        color: #fde68a;
    }

    .inf-info-box-p {
        font-size: 0.875rem;
        margin: 0;
    }
</style>
