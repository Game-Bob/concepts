---
import ThemeBoot from "@jjlmoya/identity/theme-boot";
import "@jjlmoya/identity/styles.css";
import type { Language } from "../i18n/languages";
import type { AlternateLink } from "../routing/routes";
import type { Brand } from "../identity/brands";
import "../styles/global.css";

interface Props {
    language: Language;
    brand: Brand;
    title: string;
    description: string;
    canonical: string;
    alternates: readonly AlternateLink[];
    image?: string;
}

const { language, brand, title, description, canonical, alternates, image } = Astro.props;
const socialImage = image ? new URL(image, canonical).href : undefined;
---

<!doctype html>
<html lang={language} data-brand={brand} data-identity={brand}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <ThemeBoot />
        <title>{title}</title>
        <meta name="description" content={description} />
        {socialImage && <meta property="og:image" content={socialImage} />}
        {socialImage && <meta name="twitter:image" content={socialImage} />}
        <link rel="canonical" href={canonical} />
        {
            alternates.map(({ language: alternateLanguage, url }) => (
                <link rel="alternate" hreflang={alternateLanguage} href={url} />
            ))
        }
    </head>
    <body>
        <slot />
    </body>
</html>
