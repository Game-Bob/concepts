{
    "$schema": "./node_modules/wrangler/config-schema.json",
    "name": "gamebob-concepts-staging",
    "compatibility_date": "2026-07-22",
    "workers_dev": true,
    "preview_urls": true,
    "assets": {
        "directory": "./dist",
        "html_handling": "force-trailing-slash",
        "not_found_handling": "404-page",
    },
}
