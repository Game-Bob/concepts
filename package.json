{
    "name": "@jjlmoya/concepts",
    "version": "0.1.2",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=22.18.0 <23"
    },
    "scripts": {
        "dev": "astro dev --host --port 4323",
        "build": "astro build",
        "preview": "astro preview",
        "check": "astro check",
        "lint:code": "eslint . --max-warnings 0",
        "lint:styles": "stylelint \"src/**/*.{css,astro}\"",
        "format:check": "prettier --check .",
        "lint": "npm run lint:code && npm run lint:styles && npm run format:check",
        "test": "vitest run",
        "audit": "npm audit --audit-level=low",
        "qa": "npm run check && npm run lint && npm run test && npm run build && npm run audit",
        "cf:dry-run": "npm run build && wrangler deploy --dry-run",
        "cf:preview": "npm run build && wrangler deploy --config wrangler.staging.jsonc",
        "cf:deploy": "npm run build && wrangler deploy",
        "cf:deployments": "wrangler deployments list",
        "cf:rollback": "wrangler rollback",
        "minor": "node scripts/release.mjs minor",
        "prepare": "husky"
    },
    "dependencies": {
        "@fontsource/inter": "5.2.8",
        "@iconify-json/mdi": "1.2.3",
        "@jjlmoya/identity": "0.3.0",
        "astro": "7.1.1",
        "astro-icon": "1.1.5",
        "chart.js": "^4.5.1",
        "html2canvas": "^1.4.1"
    },
    "devDependencies": {
        "@astrojs/check": "0.9.9",
        "@types/node": "25.5.0",
        "eslint": "9.39.2",
        "eslint-plugin-astro": "1.5.0",
        "eslint-plugin-no-comments": "1.1.10",
        "husky": "9.1.7",
        "postcss-html": "1.8.1",
        "prettier": "3.6.2",
        "prettier-plugin-astro": "0.14.1",
        "stylelint": "17.4.0",
        "stylelint-config-standard": "40.0.0",
        "stylelint-declaration-strict-value": "1.11.1",
        "typescript": "5.9.3",
        "typescript-eslint": "8.49.0",
        "vitest": "4.1.10",
        "wrangler": "4.113.0"
    },
    "overrides": {
        "sharp": "^0.35.0"
    }
}
